@if (TempData["Success"] != null)
{
    <div id="toastSuccess" class="position-fixed top-0 end-0 p-3" style="z-index: 9999;">
        <div class="toast show align-items-center text-white bg-success border-0 shadow-lg" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="toastError" class="position-fixed top-0 end-0 p-3" style="z-index: 9999;">
        <div class="toast show align-items-center text-white bg-danger border-0 shadow-lg" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}

<div class="filter-area-with-lines">
    <div class="panamon-bottom-line"></div>
    <div class="panamon-bottomm-line"></div>

    <div class="filter-content">
        <form method="post" asp-page-handler="Filter" class="d-flex flex-wrap align-items-center gap-3">

            <div class="d-flex align-items-center gap-2">
                <label class="mb-0">Source</label>
                <select class="form-select" style="width: 110px;" id="SelectedSource"
                        onchange="onSourceChange(this.value)">
                    @if (Model.SelectedSource == "Assembly")
                    {
                        <option value="Assembly" selected>Assembly</option>
                        <option value="Machine">Machine</option>
                    }
                    else
                    {
                        <option value="Assembly">Assembly</option>
                        <option value="Machine" selected>Machine</option>
                    }
                </select>
            </div>

            <div class="d-flex align-items-center gap-2 @(Model.SelectedSource == "Machine" ? "filter-panel-hidden" : "")" id="lineFilterPanel">
                <label class="mb-0">Line</label>
                <select class="form-select" style="width: 60px;" id="MachineLine" name="MachineLine" asp-for="MachineLine">
                    <option value="All">All</option>
                    <option value="MCH1-01">CU</option>
                    <option value="MCH1-02">CS</option>
                </select>
            </div>

            <div class="d-flex align-items-center gap-2 @(Model.SelectedSource == "Assembly" ? "filter-panel-hidden" : "")" id="machineFilterPanel">
                <label class="mb-0">Machine</label>
                <select class="form-select" style="width: 140px;" id="SelectedMachineName" name="SelectedMachineName"
                        asp-for="SelectedMachineName">
                    <option value="All">All</option>
                    @foreach (var machine in Model.MachineNameList)
                    {
                        <option value="@machine">@machine</option>
                    }
                </select>
            </div>

            <div class="d-flex align-items-center gap-2">
                <label class="mb-0">Month</label>
                <select class="form-select" style="width: 110px;"
                        id="SelectedMonth" name="SelectedMonth" asp-for="SelectedMonth">
                    @for (int i = 1; i <= 12; i++)
                    {
                        <option value="@i">@CultureInfo.GetCultureInfo("en-US").DateTimeFormat.GetMonthName(i)</option>
                    }
                </select>
            </div>

            <div class="d-flex align-items-center gap-2">
                <label class="mb-0">Year</label>
                <select class="form-select" style="width: 80px;"
                        id="SelectedYear" name="SelectedYear" asp-for="SelectedYear">
                    @for (int i = DateTime.Now.Year; i >= 2020; i--)
                    {
                        <option value="@i">@i</option>
                    }
                </select>
            </div>

            <div class="d-flex align-items-center gap-2">
                <label class="mb-0">Shift</label>
                <div class="d-flex gap-2 shift-buttons-container">
                    <input type="checkbox" id="Shift1" name="SelectedShifts" value="1"
                    @(Model.SelectedShifts != null && Model.SelectedShifts.Contains("1") ? "checked" : "")
                           style="display: none;">
                    <label for="Shift1" class="shift-button">1</label>

                    <input type="checkbox" id="Shift2" name="SelectedShifts" value="2"
                    @(Model.SelectedShifts != null && Model.SelectedShifts.Contains("2") ? "checked" : "")
                           style="display: none;">
                    <label for="Shift2" class="shift-button">2</label>

                    <input type="checkbox" id="Shift3" name="SelectedShifts" value="3"
                    @(Model.SelectedShifts != null && Model.SelectedShifts.Contains("3") ? "checked" : "")
                           style="display: none;">
                    <label for="Shift3" class="shift-button">3</label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Search</button>
            <button type="submit" asp-page-handler="ExportExcel" class="btn btn-success">
                <i class="fas fa-file-excel me-1"></i> Export CSV
            </button>
            <button type="submit" asp-page-handler="Reset" class="btn btn-danger">Reset</button>

            @if (Model.SelectedSource == "Assembly")
            {
                <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#uploadModal">
                    <i class="fas fa-file-excel me-2"></i>Upload Actual Loss
                </button>
            }

            <input type="hidden" id="hiddenSelectedSource" name="SelectedSource" value="@Model.SelectedSource" />

        </form>
    </div>
</div>

<div class="row mt-2">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-transparent">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h5 class="card-title mb-0 fw-bold fs-8 text-white">
                        Loss Time Categories — @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(Model.SelectedMonth)
                        <small class="ms-2 opacity-75" style="font-size:11px;">
                            [@Model.SelectedSource@(Model.SelectedSource == "Machine" && Model.SelectedMachineName != "All" ? $": {Model.SelectedMachineName}" : "")]
                        </small>
                        <span id="mttBadge" class="mtt-info-badge" style="display:none;">
                            <span class="mtt-dot"></span> Machine &amp; Tools Trouble Only
                        </span>
                    </h5>

                    <select id="chartCategoryFilter" onchange="onChartCategoryFilterChange(this.value)"
                            title="Filter chart view">
                        <option value="all">All Categories</option>
                        <option value="mtt">Machine &amp; Tools Trouble</option>
                    </select>
                </div>
            </div>
            <div class="card-body">
                <canvas id="lossTimeChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-transparent">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0 fw-bold fs-8 text-white">
                        Detail Loss Time
                        <span id="tableFilterBadge" style="display:none; font-size:10px; font-weight:400;
                                       background:rgba(201,203,207,0.2); border:1px solid rgba(201,203,207,0.4);
                                       border-radius:999px; padding:1px 7px; margin-left:5px; color:rgba(255,255,255,0.7);">
                            M&amp;T Trouble
                        </span>
                    </h5>
                    <select id="sortSelect" onchange="applySortTable(this.value)"
                            style="height:24px; padding:0 8px; font-size:11px; border-radius:999px;
                                       background-color:#1f2a44; border:1px solid #5c7cfa;
                                       color:#e0e1dd; cursor:pointer; outline:none;">
                        <option value="default">Date</option>
                        <option value="loss">Loss</option>
                    </select>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.HasDataToDisplay)
                {
                    <div class="table-responsive" style="height: 100%;">
                        <table class="table table-hover table-striped mb-0 text-white" id="lossTimeTable">
                            <thead class="sticky-top bg-dark text-white">
                                <tr>
                                    <th>No.</th>
                                    <th>Date</th>
                                    <th>Category</th>
                                    @if (Model.SelectedSource == "Assembly")
                                    {
                                        <th>Start</th>
                                        <th>End</th>
                                    }
                                    <th>Duration</th>
                                    <th>Location</th>
                                    <th>Shift</th>
                                    <th>Detail</th>
                                </tr>
                            </thead>
                            <tbody id="lossTimeTableBody">
                                @foreach (var item in Model.LossTimeData.Select((data, index) => new { Data = data, Index = index + 1 + (Model.CurrentPage - 1) * Model.PageSize }))
                                {
                                    bool isMTT = item.Data.Category == "Machine & Tools Trouble";
                                    <tr data-category="@item.Data.Category" class="@(isMTT ? "mtt-row" : "non-mtt-row")">
                                        <td>@item.Index</td>
                                        <td>@item.Data.Date.ToString("dd-MM-yyyy")</td>
                                        <td>
                                            @if (isMTT)
                                            {
                                                <span style="display:inline-flex;align-items:center;gap:4px;">
                                                    <span style="width:6px;height:6px;border-radius:50%;background:#C9CBCF;flex-shrink:0;"></span>
                                                    @(Model.CategoryFullNames.ContainsKey(item.Data.Category) ? Model.CategoryFullNames[item.Data.Category] : item.Data.Category)
                                                </span>
                                            }
                                            else
                                            {
                                                @(Model.CategoryFullNames.ContainsKey(item.Data.Category) ? Model.CategoryFullNames[item.Data.Category] : item.Data.Category)
                                            }
                                        </td>
                                        @if (Model.SelectedSource == "Assembly")
                                        {
                                            <td>@item.Data.Start.ToString(@"hh\:mm\:ss")</td>
                                            <td>@item.Data.End.ToString(@"hh\:mm\:ss")</td>
                                        }
                                        <td>@Math.Round(item.Data.Duration / 60.0, 1) min</td>
                                        <td>@item.Data.Location</td>
                                        <td>@item.Data.Shift</td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-info text-white"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#detailedReasonModal"
                                                    data-reason="@item.Data.DetailedReason"
                                                    data-record-id="@item.Data.RecordId"
                                                    data-record-source="@Model.SelectedSource">
                                                View
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tbody id="mttAllDataBody" style="display:none;">
                                @foreach (var item in Model.AllMttRecords.Select((data, index) => new { Data = data, Index = index + 1 }))
                                {
                                    <tr data-detailed-reason="@item.Data.DetailedReason">
                                        <td>@item.Index</td>
                                        <td>@item.Data.Date.ToString("dd-MM-yyyy")</td>
                                        <td>
                                            <span style="display:inline-flex;align-items:center;gap:4px;">
                                                <span style="width:6px;height:6px;border-radius:50%;background:#C9CBCF;flex-shrink:0;"></span>
                                                Machine &amp; Tools Trouble
                                            </span>
                                        </td>
                                        @if (Model.SelectedSource == "Assembly")
                                        {
                                            <td>@item.Data.Start.ToString(@"hh\:mm\:ss")</td>
                                            <td>@item.Data.End.ToString(@"hh\:mm\:ss")</td>
                                        }
                                        <td>@Math.Round(item.Data.Duration / 60.0, 1) min</td>
                                        <td>@item.Data.Location</td>
                                        <td>@item.Data.Shift</td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-info text-white"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#detailedReasonModal"
                                                    data-reason="@item.Data.DetailedReason"
                                                    data-record-id="@item.Data.RecordId"
                                                    data-record-source="@Model.SelectedSource">
                                                View
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center" style="height: 350px;">
                        <div class="text-center text-muted">
                            <i class="fas fa-inbox fa-3x mb-3"></i>
                            <h5>No Data Available</h5>
                            <p>No records found for the selected criteria.</p>
                        </div>
                    </div>
                }
            </div>
            @if (Model.HasDataToDisplay)
            {
                <div class="card-footer bg-transparent border-top border-secondary">
                    <div class="d-flex justify-content-between align-items-center text-white">
                        <div>
                            <span class="fw-bold">Total: @Model.TotalRecords records</span>
                            <span id="mttCountBadge" style="display:none; font-size:10px; margin-left:6px;
                                       color:rgba(201,203,207,0.8);">
                                (<span id="mttCountNum">0</span> M&amp;T Trouble)
                            </span>
                        </div>
                        <nav aria-label="Page navigation" id="paginationNav">
                            <ul class="pagination mb-0">
                                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                    <form method="post" asp-page-handler="ChangePage">
                                        <input type="hidden" name="pageNumber" value="@(Model.CurrentPage - 1)" />
                                        <input type="hidden" name="pageSize" value="10" />
                                        <input type="hidden" name="selectedMonth" value="@Model.SelectedMonth" />
                                        <input type="hidden" name="selectedYear" value="@Model.SelectedYear" />
                                        <input type="hidden" name="machineLine" value="@Model.MachineLine" />
                                        <input type="hidden" name="selectedSource" value="@Model.SelectedSource" />
                                        <input type="hidden" name="selectedMachineName" value="@Model.SelectedMachineName" />
                                        @foreach (var shift in Model.SelectedShifts)
                                        {
                                            <input type="hidden" name="selectedShifts" value="@shift" />
                                        }
                                        <input type="hidden" name="additionalBreakTime1Start" value="@Model.AdditionalBreakTime1Start" />
                                        <input type="hidden" name="additionalBreakTime1End" value="@Model.AdditionalBreakTime1End" />
                                        <input type="hidden" name="additionalBreakTime2Start" value="@Model.AdditionalBreakTime2Start" />
                                        <input type="hidden" name="additionalBreakTime2End" value="@Model.AdditionalBreakTime2End" />
                                        <button type="submit" class="page-link">&lsaquo;</button>
                                    </form>
                                </li>
                                <li class="page-item active"><span class="page-link">@Model.CurrentPage</span></li>
                                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                                    <form method="post" asp-page-handler="ChangePage">
                                        <input type="hidden" name="pageNumber" value="@(Model.CurrentPage + 1)" />
                                        <input type="hidden" name="pageSize" value="10" />
                                        <input type="hidden" name="selectedMonth" value="@Model.SelectedMonth" />
                                        <input type="hidden" name="selectedYear" value="@Model.SelectedYear" />
                                        <input type="hidden" name="machineLine" value="@Model.MachineLine" />
                                        <input type="hidden" name="selectedSource" value="@Model.SelectedSource" />
                                        <input type="hidden" name="selectedMachineName" value="@Model.SelectedMachineName" />
                                        @foreach (var shift in Model.SelectedShifts)
                                        {
                                            <input type="hidden" name="selectedShifts" value="@shift" />
                                        }
                                        <input type="hidden" name="additionalBreakTime1Start" value="@Model.AdditionalBreakTime1Start" />
                                        <input type="hidden" name="additionalBreakTime1End" value="@Model.AdditionalBreakTime1End" />
                                        <input type="hidden" name="additionalBreakTime2Start" value="@Model.AdditionalBreakTime2Start" />
                                        <input type="hidden" name="additionalBreakTime2End" value="@Model.AdditionalBreakTime2End" />
                                        <button type="submit" class="page-link">&rsaquo;</button>
                                    </form>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- DAILY CHART ROW -->
<div class="row mt-2" style="margin-bottom: 2px; margin-left: -18px; margin-right: -18px;">
    <div class="col-12" style="padding-left: 5px; padding-right: 5px;">
        <div class="card shadow-sm">
            <div class="card-header bg-transparent">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h5 class="card-title mb-0 fw-bold fs-8 text-white" id="dailyChartTitle">
                        Daily Loss Time — @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(Model.SelectedMonth)
                    </h5>
                    <div id="mttTopInfoBar" style="display:none; background:rgba(201,203,207,0.08); border:1px solid rgba(201,203,207,0.25); border-radius:8px; padding:4px 12px; font-size:11px; color:rgba(255,255,255,0.75);">
                        <i class="fas fa-cog me-1" style="color:#C9CBCF;"></i>
                        Dominant: <span id="mttTopSubCatLabel" class="mtt-top-label" style="font-weight:700; color:#C9CBCF; margin:0 4px;">—</span>
                        <span id="mttTopSubCatTotal" style="opacity:0.7;"></span>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <canvas id="dailyLossChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- UPLOAD MODAL (Assembly only) -->
<div class="modal fade" id="uploadModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="uploadModalLabel"><i class="fas fa-file-upload"></i> Upload Actual Loss Data Daily</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="uploadForm" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">1. Choose Excel File</label>
                        <input type="file" name="UploadedExcel" class="form-control" accept=".xlsx" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">2. Select Target Machine for Actual Data</label>
                        <select name="UploadMachineLine" class="form-select" required>
                            <option value="">-- Pilih Machine --</option>
                            <option value="MCH1-01">MCH1-01 (CU)</option>
                            <option value="MCH1-02">MCH1-02 (CS)</option>
                        </select>
                        <div class="form-text text-muted">You must specify which machine this file belongs to.</div>
                    </div>
                    <hr />
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="TargetMonth" class="form-label">Untuk Bulan:</label>
                            <select id="TargetMonth" name="TargetMonth" class="form-select" required>
                                @for (int i = 1; i <= 12; i++)
                                {
                                    <option value="@i">@CultureInfo.GetCultureInfo("en-US").DateTimeFormat.GetMonthName(i)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="TargetYear" class="form-label">Untuk Tahun:</label>
                            <select id="TargetYear" name="TargetYear" class="form-select" required>
                                @for (int i = DateTime.Now.Year - 3; i <= DateTime.Now.Year + 5; i++)
                                {
                                    <option value="@i">@i</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="small text-muted">Need the format?</span>
                        <a asp-page-handler="DownloadTemplateActualLoss" class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-download"></i> Download Template
                        </a>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" id="btnSubmitUpload" class="btn btn-small text-white" style="background-color: rgb(25, 135, 84);">
                        <i class="fas fa-file-upload me-2"></i>Import Actual Loss Data
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- DETAILED REASON MODAL -->
<div class="modal fade" id="detailedReasonModal" tabindex="-1" aria-labelledby="detailedReasonModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-white">
            <div class="modal-header">
                <h5 class="modal-title" id="detailedReasonModalLabel">Detailed Reason</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="detailedReasonViewMode">
                    <p id="detailedReasonText" style="white-space: pre-wrap;"></p>
                </div>
                <div id="detailedReasonEditMode" style="display:none;">
                    <textarea id="detailedReasonTextarea" class="form-control bg-dark text-white border-secondary"
                              rows="5" style="resize: vertical; font-size:14px;"></textarea>
                    <div id="editReasonError" class="text-danger mt-1" style="font-size:12px; display:none;"></div>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between align-items-center">
                <div>
                    <button type="button" id="btnEditReason" class="btn btn-warning btn-sm text-dark fw-bold">
                        <i class="fas fa-pencil-alt me-1"></i> Edit
                    </button>
                    <button type="button" id="btnSaveReason" class="btn btn-success btn-sm fw-bold" style="display:none;">
                        <i class="fas fa-save me-1"></i> Save
                    </button>
                    <button type="button" id="btnCancelEdit" class="btn btn-secondary btn-sm" style="display:none;">
                        Cancel
                    </button>
                </div>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    console.log("🚀 Script START");

    const isLightModeActive = () => document.body.classList.contains('light-mode');

    const getChartColors = () => {
        if (isLightModeActive()) {
            return {
                textColor: '#1a1a2e',
                gridColor: 'rgba(0,0,0,0.1)',
                legendColor: '#1a1a2e',
                tooltipBg: 'rgba(255,255,255,0.9)',
                tooltipBorder: 'rgba(0,0,0,0.2)'
            };
        } else {
            return {
                textColor: '#ffffff',
                gridColor: 'rgba(255,255,255,0.1)',
                legendColor: '#ffffff',
                tooltipBg: 'rgba(0,0,0,0.8)',
                tooltipBorder: 'rgba(255,255,255,0.2)'
            };
        }
    };

    const MTT_CATEGORY_NAME = "Machine & Tools Trouble";

    let currentCategoryFilter = 'all';
    let summaryChartInstance = null;
    let dailyChartInstance = null;
    let activeMttSubCategoryFilter = null;

    let summaryChartData = null;
    let dailyChartData = null;
    let mttDailyChartData = null;

    try {
        summaryChartData = JSON.parse('@Html.Raw(Model.ChartDataJson)');
    } catch (e) {
        console.error("❌ Parse Summary Error:", e);
        summaryChartData = { labels: [], fullLabels: [], shift1Data: [], shift2Data: [], shift3Data: [], lastMonthData: [] };
    }

    try {
        dailyChartData = JSON.parse('@Html.Raw(Model.DailyChartDataJson)');
    } catch (e) {
        console.error("❌ Parse Daily Error:", e);
        dailyChartData = { labels: [], datasets: [] };
    }

    try {
        mttDailyChartData = JSON.parse('@Html.Raw(Model.MttDailyChartDataJson)');
    } catch (e) {
        console.error("❌ Parse MTT Daily Error:", e);
        mttDailyChartData = { labels: [], datasets: [], topSubCategory: '', topSubCategoryTotal: 0 };
    }

    function onChartCategoryFilterChange(mode) {
        currentCategoryFilter = mode;
        activeMttSubCategoryFilter = null;
        const tableFilterBadge = document.getElementById('tableFilterBadge');
        if (tableFilterBadge) tableFilterBadge.style.display = (mode === 'mtt') ? 'inline' : 'none';
        filterSummaryChart(mode);
        filterTableRows(mode);
        switchDailyChart(mode);
    }

    function filterSummaryChart(mode) {
        if (!summaryChartInstance) return;

        if (mode === 'mtt') {
            const mttDatasets = mttDailyChartData.datasets || [];
            if (mttDatasets.length === 0) {
                summaryChartInstance.data.labels = ['No MTT Data'];
                summaryChartInstance.data.datasets = [];
                summaryChartInstance.update('none');
                renderSummaryLegend(mode, []);
                return;
            }

            const subCatTotals = mttDatasets.map(ds => ({
                label: ds.label,
                total: (ds.data || []).reduce((a, b) => a + b, 0),
                color: ds.backgroundColor
            })).sort((a, b) => b.total - a.total);

            summaryChartInstance.data.labels = subCatTotals.map(x => x.label);
            summaryChartInstance.data.datasets = [{
                label: 'MTT Duration',
                data: subCatTotals.map(x => Math.round(x.total * 10) / 10),
                backgroundColor: subCatTotals.map(x => x.color),
                borderWidth: 0,
                minBarLength: 5
            }];

            summaryChartInstance.options.scales.x.title.text = 'Sub-category';
            summaryChartInstance.options.plugins.legend.display = false;
            summaryChartInstance.options.plugins.tooltip.callbacks.title = (ctx) => ctx[0]?.label || '';
            summaryChartInstance.options.plugins.tooltip.callbacks.label = (c) => `Total: ${c.raw} min`;
            summaryChartInstance.options.scales.x.stacked = false;
            summaryChartInstance.options.scales.y.stacked = false;

            summaryChartInstance.update('none');
            renderSummaryLegend(mode, subCatTotals);

        } else {
            summaryChartInstance.data.labels = summaryChartData.labels || [];
            summaryChartInstance.data.datasets = [
                {
                    label: 'Last Month',
                    data: summaryChartData.lastMonthData || [],
                    backgroundColor: 'rgba(201,203,207,0.95)',
                    stack: 'last',
                    minBarLength: 5
                },
                {
                    label: 'Shift 1',
                    data: summaryChartData.shift1Data || [],
                    backgroundColor: 'rgba(255,99,132,0.95)',
                    stack: 'current',
                    minBarLength: 5
                },
                {
                    label: 'Shift 2',
                    data: summaryChartData.shift2Data || [],
                    backgroundColor: 'rgba(54,162,235,0.95)',
                    stack: 'current',
                    minBarLength: 5
                },
                {
                    label: 'Shift 3',
                    data: summaryChartData.shift3Data || [],
                    backgroundColor: 'rgba(75,192,192,0.95)',
                    stack: 'current',
                    minBarLength: 5
                }
            ];

            summaryChartInstance.options.scales.x.title.text = 'Categories';
            summaryChartInstance.options.scales.x.stacked = true;
            summaryChartInstance.options.scales.y.stacked = true;
            summaryChartInstance.options.plugins.legend.display = true;
            summaryChartInstance.options.plugins.tooltip.callbacks.title = (ctx) => {
                const label = (summaryChartData.fullLabels || [])[ctx[0].dataIndex] || '';
                return label === MTT_CATEGORY_NAME ? '⚙️ ' + label : label;
            };
            summaryChartInstance.options.plugins.tooltip.callbacks.label = (c) => `${c.dataset.label}: ${c.raw} min`;

            summaryChartInstance.update('none');
            renderSummaryLegend(mode, []);
        }
    }

    function renderSummaryLegend(mode, subCatTotals) {
        const mttBadge = document.getElementById('mttBadge');
        if (!mttBadge) return;

        if (mode === 'mtt' && subCatTotals.length > 0) {
            const top = subCatTotals[0];
            mttBadge.style.display = 'inline-flex';
            mttBadge.innerHTML = `
                <span style="width:8px;height:8px;border-radius:50%;background:${top.color};flex-shrink:0;"></span>
                Top: ${top.label} (${Math.round(top.total * 10) / 10} min)
            `;
        } else {
            mttBadge.style.display = 'none';
            mttBadge.innerHTML = `<span class="mtt-dot"></span> Machine &amp; Tools Trouble Only`;
        }
    }

    function switchDailyChart(mode) {
        if (!dailyChartInstance) return;

        const monthName = '@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(Model.SelectedMonth)';
        const titleEl = document.getElementById('dailyChartTitle');
        const mttInfoBar = document.getElementById('mttTopInfoBar');
        const mttTopLabel = document.getElementById('mttTopSubCatLabel');
        const mttTopTotal = document.getElementById('mttTopSubCatTotal');

        if (mode === 'mtt') {
            if (titleEl) titleEl.innerHTML = `Daily Loss Time — ${monthName} <small class="ms-2 opacity-75" style="font-size:11px;">⚙️ Machine &amp; Tools Trouble Breakdown</small>`;

            const mttDatasets = (mttDailyChartData.datasets || []);

            if (mttDatasets.length === 0) {
                dailyChartInstance.data.datasets = [];
                dailyChartInstance.data.labels = mttDailyChartData.labels || dailyChartData.labels || [];
                dailyChartInstance.update('none');
                if (mttInfoBar) mttInfoBar.style.display = 'none';
                return;
            }

            dailyChartInstance.data.labels = mttDailyChartData.labels || dailyChartData.labels;
            dailyChartInstance.data.datasets = mttDatasets.map(ds => ({
                label: ds.label,
                data: ds.data,
                backgroundColor: ds.backgroundColor,
                stack: 'MttStack'
            }));
            dailyChartInstance.update('none');

            const topSubCat = mttDailyChartData.topSubCategory || '';
            const topTotal = mttDailyChartData.topSubCategoryTotal || 0;
            if (mttInfoBar && topSubCat) {
                if (mttTopLabel) mttTopLabel.textContent = topSubCat;
                if (mttTopTotal) mttTopTotal.textContent = `(${topTotal} min total)`;
                mttInfoBar.style.display = 'flex';
            } else if (mttInfoBar) {
                mttInfoBar.style.display = 'none';
            }

        } else {
            if (titleEl) titleEl.innerHTML = `Daily Loss Time — ${monthName}`;

            dailyChartInstance.data.labels = dailyChartData.labels || [];
            dailyChartInstance.data.datasets = (dailyChartData.datasets || []).map(ds => ({
                label: ds.label,
                data: ds.data,
                backgroundColor: ds.backgroundColor,
                stack: 'DayStack'
            }));
            dailyChartInstance.update('none');

            if (mttInfoBar) mttInfoBar.style.display = 'none';
        }
    }

    function filterTableRows(mode) {
        const paginatedBody = document.getElementById('lossTimeTableBody');
        const mttAllBody = document.getElementById('mttAllDataBody');
        const paginationNav = document.getElementById('paginationNav');

        if (mode === 'mtt') {
            if (paginatedBody) paginatedBody.style.display = 'none';
            if (mttAllBody) mttAllBody.style.display = '';
            if (paginationNav) paginationNav.style.display = 'none';

            applyMttSubCategoryFilterToTable(activeMttSubCategoryFilter);

            const mttBody = document.getElementById('mttAllDataBody');
            const visibleCount = mttBody
                ? Array.from(mttBody.querySelectorAll('tr')).filter(r => r.style.display !== 'none').length
                : 0;
            const mttCountBadge = document.getElementById('mttCountBadge');
            const mttCountNum = document.getElementById('mttCountNum');
            if (mttCountBadge && mttCountNum) {
                mttCountNum.textContent = visibleCount;
                mttCountBadge.style.display = 'inline';
            }
        } else {
            if (paginatedBody) paginatedBody.style.display = '';
            if (mttAllBody) mttAllBody.style.display = 'none';
            if (paginationNav) paginationNav.style.display = '';

            const mttCountBadge = document.getElementById('mttCountBadge');
            if (mttCountBadge) mttCountBadge.style.display = 'none';
        }
    }

    function applyMttSubCategoryFilterToTable(subCat) {
        const mttAllBody = document.getElementById('mttAllDataBody');
        if (!mttAllBody) return;

        const rows = mttAllBody.querySelectorAll('tr');
        const tableFilterBadge = document.getElementById('tableFilterBadge');

        if (!subCat) {
            rows.forEach(r => r.style.display = '');
            if (tableFilterBadge) {
                tableFilterBadge.textContent = 'M&T Trouble';
                tableFilterBadge.style.display = 'inline';
            }
            return;
        }

        let visibleCount = 0;
        rows.forEach(r => {
            const detailedReason = (r.getAttribute('data-detailed-reason') || '').toLowerCase();
            const subCatLower = subCat.toLowerCase();
            const match = detailedReason.includes(subCatLower) || matchMttKeyword(detailedReason, subCat);
            r.style.display = match ? '' : 'none';
            if (match) visibleCount++;
        });

        if (tableFilterBadge) {
            tableFilterBadge.textContent = subCat;
            tableFilterBadge.style.display = 'inline';
        }

        const mttCountNum = document.getElementById('mttCountNum');
        if (mttCountNum) mttCountNum.textContent = visibleCount;
    }

    function matchMttKeyword(detailedReasonLower, subCat) {
        const sc = subCat.toLowerCase();
        if (sc === 'vaccum' && (detailedReasonLower.includes('vaccum') || detailedReasonLower.includes('vacuum'))) return true;
        if (sc === 'laser' && detailedReasonLower.includes('laser')) return true;
        if (sc === 'conveyor' && detailedReasonLower.includes('conveyor')) return true;
        if (sc === 'driver' && detailedReasonLower.includes('driver')) return true;
        if (sc === 'gas charge' && detailedReasonLower.includes('gas')) return true;
        if (sc === 'bending condensor reguler' && detailedReasonLower.includes('bending')) return true;
        if (sc === 'straping band' && (detailedReasonLower.includes('straping') || detailedReasonLower.includes('strapping'))) return true;
        if (sc === 'lifter prouduct' && detailedReasonLower.includes('lifter')) return true;
        if (sc === 'running trip' && (detailedReasonLower.includes('running') || detailedReasonLower.includes('trip'))) return true;
        if (sc === 'scanner fm cu' && detailedReasonLower.includes('scanner') && !detailedReasonLower.includes(' cs')) return true;
        return false;
    }

    function applySortTable(mode) {
        const getDuration = (row) => {
            for (let i = 0; i < row.cells.length; i++) {
                const txt = row.cells[i].textContent.trim();
                if (txt.endsWith('min')) return parseFloat(txt) || 0;
            }
            return 0;
        };

        const tbody = document.getElementById('lossTimeTableBody');
        if (tbody) {
            const rows = Array.from(tbody.querySelectorAll('tr'));
            if (mode === 'loss') {
                rows.sort((a, b) => getDuration(b) - getDuration(a));
            } else {
                rows.sort((a, b) => (parseInt(a.cells[0].textContent) || 0) - (parseInt(b.cells[0].textContent) || 0));
            }
            rows.forEach(r => tbody.appendChild(r));
        }

        const mttBody = document.getElementById('mttAllDataBody');
        if (mttBody) {
            const mttRows = Array.from(mttBody.querySelectorAll('tr'));
            if (mode === 'loss') {
                mttRows.sort((a, b) => getDuration(b) - getDuration(a));
            } else {
                mttRows.sort((a, b) => (parseInt(a.cells[0].textContent) || 0) - (parseInt(b.cells[0].textContent) || 0));
            }
            mttRows.forEach(r => mttBody.appendChild(r));
        }

        filterTableRows(currentCategoryFilter);
    }

    function showCustomToast(message, type = 'success') {
        const toastContainer = document.createElement('div');
        toastContainer.className = `custom-toast ${type}`;
        let icon = 'fas fa-check-circle';
        if (type === 'error') icon = 'fas fa-exclamation-circle';
        if (type === 'info') icon = 'fas fa-info-circle';
        toastContainer.innerHTML = `<i class="${icon}"></i><span>${message}</span>`;
        document.body.appendChild(toastContainer);
        setTimeout(() => {
            toastContainer.classList.add('hide');
            setTimeout(() => toastContainer.remove(), 300);
        }, 4000);
    }

    function onSourceChange(val) {
        const linePanel = document.getElementById('lineFilterPanel');
        const machinePanel = document.getElementById('machineFilterPanel');
        const hiddenSrc = document.getElementById('hiddenSelectedSource');
        if (val === 'Machine') {
            linePanel.classList.add('filter-panel-hidden');
            machinePanel.classList.remove('filter-panel-hidden');
        } else {
            linePanel.classList.remove('filter-panel-hidden');
            machinePanel.classList.add('filter-panel-hidden');
        }
        if (hiddenSrc) hiddenSrc.value = val;
    }

    document.addEventListener('DOMContentLoaded', function () {
        const form = document.querySelector('form[method="post"]');
        if (form) {
            form.addEventListener('submit', function () {
                const hidden = document.getElementById('hiddenSelectedSource');
                const select = document.getElementById('SelectedSource');
                if (hidden && select) hidden.value = select.value;
            });
        }
    });

    document.addEventListener('DOMContentLoaded', function () {
        ['toastSuccess', 'toastError'].forEach(id => {
            const el = document.getElementById(id);
            if (el) setTimeout(() => el.style.display = 'none', 4000);
        });
    });

    function updateDropdownStyle() {
        try {
            const dropdowns = document.querySelectorAll('.filter-content .form-select');
            dropdowns.forEach(dropdown => {
                const v = dropdown.value;
                if (v && v !== 'All') dropdown.classList.add('selected');
                else dropdown.classList.remove('selected');
            });
        } catch (e) { console.error("❌ Dropdown error:", e); }
    }

    function initializeCharts() {
        if (typeof Chart === 'undefined') { console.error("❌ Chart.js NOT LOADED!"); return; }
        try {
            Chart.defaults.animation = false;
            Chart.defaults.animations = {};
            Chart.defaults.transitions = {};

            const colors = getChartColors();

            const ctxSummary = document.getElementById('lossTimeChart');
            if (ctxSummary) {
                summaryChartInstance = new Chart(ctxSummary, {
                    type: 'bar',
                    data: {
                        labels: summaryChartData.labels || [],
                        datasets: [
                            {
                                label: 'Last Month',
                                data: summaryChartData.lastMonthData || [],
                                backgroundColor: 'rgba(201,203,207,0.95)',
                                stack: 'last',
                                minBarLength: 5,
                                _originalSolidColor: 'rgba(201,203,207,0.95)'
                            },
                            {
                                label: 'Shift 1',
                                data: summaryChartData.shift1Data || [],
                                backgroundColor: 'rgba(255,99,132,0.95)',
                                stack: 'current',
                                minBarLength: 5,
                                _originalSolidColor: 'rgba(255,99,132,0.95)'
                            },
                            {
                                label: 'Shift 2',
                                data: summaryChartData.shift2Data || [],
                                backgroundColor: 'rgba(54,162,235,0.95)',
                                stack: 'current',
                                minBarLength: 5,
                                _originalSolidColor: 'rgba(54,162,235,0.95)'
                            },
                            {
                                label: 'Shift 3',
                                data: summaryChartData.shift3Data || [],
                                backgroundColor: 'rgba(75,192,192,0.95)',
                                stack: 'current',
                                minBarLength: 5,
                                _originalSolidColor: 'rgba(75,192,192,0.95)'
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: false,
                        plugins: {
                            legend: {
                                labels: {
                                    color: colors.legendColor,
                                    font: { size: 12 }
                                }
                            },
                            tooltip: {
                                bodyColor: colors.textColor, titleColor: colors.textColor,
                                borderColor: colors.tooltipBorder, backgroundColor: colors.tooltipBg,
                                callbacks: {
                                    title: (ctx) => {
                                        const label = (summaryChartData.fullLabels || [])[ctx[0].dataIndex] || '';
                                        const isMTT = label === MTT_CATEGORY_NAME;
                                        return isMTT ? '⚙️ ' + label : label;
                                    },
                                    label: (c) => `${c.dataset.label}: ${c.raw} min`
                                }
                            }
                        },
                        scales: {
                            x: {
                                stacked: true,
                                ticks: {
                                    color: function (ctx) {
                                        const label = (summaryChartData.labels || [])[ctx.index] || '';
                                        const isMTT = label === MTT_CATEGORY_NAME ||
                                            (label.toLowerCase().includes('machine') && label.toLowerCase().includes('tools'));
                                        if (currentCategoryFilter === 'mtt' && isMTT) return colors.textColor;
                                        if (currentCategoryFilter === 'mtt' && !isMTT) return 'rgba(150,150,150,0.35)';
                                        return colors.textColor;
                                    },
                                    maxRotation: 0, minRotation: 0,
                                    callback: function (value) {
                                        const label = this.getLabelForValue(value);
                                        const words = label.split(' ');
                                        const lines = [];
                                        let current = '';
                                        words.forEach(word => {
                                            if ((current + ' ' + word).trim().length > 10) {
                                                if (current) lines.push(current);
                                                current = word;
                                            } else {
                                                current = (current + ' ' + word).trim();
                                            }
                                        });
                                        if (current) lines.push(current);
                                        return lines;
                                    }
                                },
                                grid: { color: colors.gridColor },
                                title: { display: true, text: 'Categories', color: colors.textColor }
                            },
                            y: {
                                beginAtZero: true, stacked: true,
                                ticks: { color: colors.textColor },
                                grid: { color: colors.gridColor },
                                title: { display: true, text: 'Duration (Min)', color: colors.textColor }
                            }
                        },
                        onClick: function (evt, elements) {
                            if (currentCategoryFilter !== 'mtt') return;
                            if (!elements || elements.length === 0) {
                                activeMttSubCategoryFilter = null;
                                applyMttSubCategoryFilterToTable(null);
                                const mttAllBody = document.getElementById('mttAllDataBody');
                                const mttCountNum = document.getElementById('mttCountNum');
                                if (mttAllBody && mttCountNum) {
                                    mttCountNum.textContent = mttAllBody.querySelectorAll('tr').length;
                                }
                                return;
                            }
                            const idx = elements[0].index;
                            const clickedLabel = summaryChartInstance.data.labels[idx];
                            if (!clickedLabel) return;
                            if (activeMttSubCategoryFilter === clickedLabel) {
                                activeMttSubCategoryFilter = null;
                                applyMttSubCategoryFilterToTable(null);
                                const mttAllBody = document.getElementById('mttAllDataBody');
                                const mttCountNum = document.getElementById('mttCountNum');
                                if (mttAllBody && mttCountNum) {
                                    mttCountNum.textContent = mttAllBody.querySelectorAll('tr').length;
                                }
                            } else {
                                activeMttSubCategoryFilter = clickedLabel;
                                applyMttSubCategoryFilterToTable(clickedLabel);
                            }
                        }
                    }
                });
            }

            const ctxDaily = document.getElementById('dailyLossChart');
            if (ctxDaily) {
                dailyChartInstance = new Chart(ctxDaily, {
                    type: 'bar',
                    data: {
                        labels: dailyChartData.labels || [],
                        datasets: (dailyChartData.datasets || []).map(ds => ({
                            label: ds.label,
                            data: ds.data,
                            backgroundColor: ds.backgroundColor,
                            stack: 'DayStack'
                        }))
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: false,
                        plugins: {
                            legend: {
                                position: 'top',
                                labels: {
                                    color: colors.legendColor,
                                    font: { size: 12 }
                                }
                            },
                            tooltip: {
                                bodyColor: colors.textColor, titleColor: colors.textColor,
                                borderColor: colors.tooltipBorder, backgroundColor: colors.tooltipBg,
                                mode: 'index', intersect: false,
                                callbacks: { label: (c) => `${c.dataset.label}: ${c.raw} min` }
                            }
                        },
                        scales: {
                            x: {
                                stacked: true,
                                ticks: { color: colors.textColor },
                                grid: { color: colors.gridColor },
                                title: { display: true, text: 'Day of Month', color: colors.textColor }
                            },
                            y: {
                                beginAtZero: true, stacked: true,
                                ticks: { color: colors.textColor },
                                grid: { color: colors.gridColor },
                                title: { display: true, text: 'Duration (Min)', color: colors.textColor }
                            }
                        }
                    }
                });
            }

        } catch (error) {
            console.error("❌ Chart error:", error);
        }

        requestAnimationFrame(function () {
            if (summaryChartInstance) summaryChartInstance.resize();
            if (dailyChartInstance) dailyChartInstance.resize();
        });
    }

    function initializeOtherFeatures() {
        try {
            const shiftCheckboxes = document.querySelectorAll('input[name="SelectedShifts"]');
            shiftCheckboxes.forEach(checkbox => {
                const button = document.querySelector(`label[for="${checkbox.id}"]`);
                if (checkbox.checked && button) button.classList.add('active');
            });
            const shiftButtons = document.querySelectorAll('.shift-button');
            shiftButtons.forEach(button => {
                button.addEventListener('click', function (e) {
                    e.preventDefault();
                    const checkbox = document.getElementById(this.getAttribute('for'));
                    if (checkbox) {
                        checkbox.checked = !checkbox.checked;
                        this.classList.toggle('active', checkbox.checked);
                    }
                });
            });
        } catch (e) { console.error("❌ Shift error:", e); }

        try {
            setTimeout(updateDropdownStyle, 50);
            document.querySelectorAll('.filter-content .form-select').forEach(d => d.addEventListener('change', updateDropdownStyle));
        } catch (e) { console.error("❌ Dropdown error:", e); }

        try {
            const src = document.getElementById('SelectedSource');
            if (src) onSourceChange(src.value);
        } catch (e) { console.error("❌ Source init error:", e); }

        try {
            const detailedReasonModal = document.getElementById('detailedReasonModal');
            if (detailedReasonModal) {
                detailedReasonModal.addEventListener('show.bs.modal', function (event) {
                    const btn = event.relatedTarget;
                    const reason = btn.getAttribute('data-reason');
                    const recordId = btn.getAttribute('data-record-id');
                    const recordSource = btn.getAttribute('data-record-source');

                    this.setAttribute('data-current-record-id', recordId || '');
                    this.setAttribute('data-current-record-source', recordSource || '');

                    const p = this.querySelector('#detailedReasonText');
                    p.textContent = (reason && reason.trim() !== '') ? reason : 'No detailed reason provided.';

                    setReasonViewMode();
                });
            }

            document.getElementById('btnEditReason')?.addEventListener('click', function () {
                const currentText = document.getElementById('detailedReasonText').textContent;
                document.getElementById('detailedReasonTextarea').value =
                    currentText === 'No detailed reason provided.' ? '' : currentText;
                document.getElementById('editReasonError').style.display = 'none';
                setReasonEditMode();
            });

            document.getElementById('btnCancelEdit')?.addEventListener('click', function () {
                setReasonViewMode();
            });

            document.getElementById('btnSaveReason')?.addEventListener('click', async function () {
                const modal = document.getElementById('detailedReasonModal');
                const recordId = modal.getAttribute('data-current-record-id');
                const recordSource = modal.getAttribute('data-current-record-source');
                const newReason = document.getElementById('detailedReasonTextarea').value.trim();
                const errorEl = document.getElementById('editReasonError');

                if (!recordId) {
                    errorEl.textContent = 'Record ID tidak ditemukan. Data ini mungkin tidak bisa diedit.';
                    errorEl.style.display = 'block';
                    return;
                }

                this.disabled = true;
                this.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Saving...';

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                        || document.querySelector('form[method="post"] input[name="__RequestVerificationToken"]')?.value;

                    const formData = new FormData();
                    formData.append('recordId', recordId);
                    formData.append('recordSource', recordSource || '');
                    formData.append('newDetailedReason', newReason);
                    if (token) formData.append('__RequestVerificationToken', token);

                    const response = await fetch('?handler=EditDetailedReason', {
                        method: 'POST',
                        headers: token ? { 'RequestVerificationToken': token } : {},
                        body: formData
                    });

                    if (response.ok) {
                        const result = await response.json();
                        if (result.success) {
                            document.getElementById('detailedReasonText').textContent =
                                newReason || 'No detailed reason provided.';

                            const allViewBtns = document.querySelectorAll(`[data-record-id="${recordId}"]`);
                            allViewBtns.forEach(b => b.setAttribute('data-reason', newReason));

                            setReasonViewMode();
                            showCustomToast('Detailed reason berhasil diperbarui', 'success');
                        } else {
                            errorEl.textContent = result.message || 'Gagal menyimpan.';
                            errorEl.style.display = 'block';
                        }
                    } else {
                        errorEl.textContent = 'Server error: ' + response.status;
                        errorEl.style.display = 'block';
                    }
                } catch (err) {
                    errorEl.textContent = 'Error: ' + err.message;
                    errorEl.style.display = 'block';
                } finally {
                    this.disabled = false;
                    this.innerHTML = '<i class="fas fa-save me-1"></i> Save';
                }
            });
        } catch (e) { console.error("❌ Modal error:", e); }

        function setReasonViewMode() {
            document.getElementById('detailedReasonViewMode').style.display = '';
            document.getElementById('detailedReasonEditMode').style.display = 'none';
            document.getElementById('btnEditReason').style.display = '';
            document.getElementById('btnSaveReason').style.display = 'none';
            document.getElementById('btnCancelEdit').style.display = 'none';
        }

        function setReasonEditMode() {
            document.getElementById('detailedReasonViewMode').style.display = 'none';
            document.getElementById('detailedReasonEditMode').style.display = '';
            document.getElementById('btnEditReason').style.display = 'none';
            document.getElementById('btnSaveReason').style.display = '';
            document.getElementById('btnCancelEdit').style.display = '';
        }
    }

    function runInit() {
        requestAnimationFrame(function () {
            requestAnimationFrame(function () {
                initializeCharts();
                initializeOtherFeatures();
            });
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', runInit);
    } else {
        runInit();
    }

    // UPLOAD HANDLER
    document.getElementById('btnSubmitUpload')?.addEventListener('click', async function (e) {
        e.preventDefault();
        const form = document.getElementById('uploadForm');
        if (!form) return;
        const file = form.querySelector('input[name="UploadedExcel"]');
        const machineLine = form.querySelector('select[name="UploadMachineLine"]');
        if (!file.files || !file.files.length) {
            showCustomToast('❌ Harap pilih file Excel terlebih dahulu', 'error');
            return;
        }
        if (!machineLine.value) {
            showCustomToast('❌ Harap pilih Machine Line', 'error');
            return;
        }
        this.disabled = true;
        const originalHTML = this.innerHTML;
        this.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Importing...';
        try {
            const formData = new FormData(form);
            const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const response = await fetch('?handler=ImportExcelActual', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token },
                body: formData
            });
            if (response.ok) {
                showCustomToast('Data berhasil diimport', 'success');
                try {
                    const modal = bootstrap.Modal.getInstance(document.getElementById('uploadModal'));
                    if (modal) modal.hide();
                } catch (e) { }
                form.reset();
                setTimeout(() => { location.reload(); }, 1500);
            } else {
                showCustomToast('Gagal import data. Status: ' + response.status, 'error');
                this.disabled = false;
                this.innerHTML = originalHTML;
            }
        } catch (error) {
            console.error('Upload error:', error);
            showCustomToast('Error: ' + error.message, 'error');
            this.disabled = false;
            this.innerHTML = originalHTML;
        }
    });
</script>
