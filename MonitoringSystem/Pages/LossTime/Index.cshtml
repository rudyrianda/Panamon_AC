        .filter-content .form-select {
            height: 28px;
            padding: 0 !important;
            padding-left: 12px !important;
            padding-right: 28px !important;
            font-size: 12px;
            line-height: 16px;
            border-radius: 999px;
            background-color: rgba(255, 255, 255, 0.05);
            border: 2px solid rgba(255, 255, 255, 0.5);
            color: #ffffff;
            text-align: center;
            appearance: none;
            -webkit-appearance: none;
            -moz-appearance: none;
