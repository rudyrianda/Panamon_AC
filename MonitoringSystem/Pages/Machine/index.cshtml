        <div class="col-md-10">
            <div class="card shadow-sm h-100">
                <div class="card-body p-0 gantt-card">
                    <div class="card-title">Shift Timeline</div>

                    <!-- SHIFT 1 -->
                    <div class="loss-line-wrapper">
                        <div style="display:flex; flex-direction:row; align-items:center; gap:10px; flex:1 1 0; min-height:0;">
                            <b class="loss-line-badge">S1</b>
                            <div class="timeline-container">
                                <div class="timeline-track-wrapper">
                                    <div id="timeline-track-s1" class="timeline-track">
                                        <div id="timeline-progress-s1" class="timeline-progress"></div>
                                    </div>
                                    <div class="timeline-minutes" id="timeline-minutes-s1"></div>
                                </div>
                                <div class="timeline-hours" id="timeline-hours-s1"></div>
                            </div>
                            <div class="loss-summary-right">
                                <div class="loss-summary-item">
                                    <span class="loss-legend-dot" style="background:#4F86F3;"></span>
                                    <span class="loss-legend-label">Load Time</span>
                                    <span id="s1-load-val" class="loss-legend-value">0</span>
                                </div>
                                <div class="loss-summary-item">
                                    <span class="loss-legend-dot" style="background:#d90429;"></span>
                                    <span class="loss-legend-label">Stop Time</span>
                                    <span id="s1-stop-val" class="loss-legend-value">0</span>
                                </div>
                                <div class="loss-summary-item">
                                    <span class="loss-legend-dot" style="visibility:hidden;"></span>
                                    <span class="loss-legend-label">Working Time</span>
                                    <span id="s1-work-val" class="loss-legend-value">0</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr style="border:none;border-top:1px solid rgba(255,255,255,0.15);margin:2px 0;">

                    <!-- SHIFT 2 -->
                    <div class="loss-line-wrapper">
                        <div style="display:flex; flex-direction:row; align-items:center; gap:10px; flex:1 1 0; min-height:0;">
                            <b class="loss-line-badge">S2</b>
                            <div class="timeline-container">
                                <div class="timeline-track-wrapper">
                                    <div id="timeline-track-s2" class="timeline-track">
                                        <div id="timeline-progress-s2" class="timeline-progress"></div>
                                    </div>
                                    <div class="timeline-minutes" id="timeline-minutes-s2"></div>
                                </div>
                                <div class="timeline-hours" id="timeline-hours-s2"></div>
                            </div>
                            <div class="loss-summary-right">
                                <div class="loss-summary-item">
                                    <span class="loss-legend-dot" style="background:#4F86F3;"></span>
                                    <span class="loss-legend-label">Load Time</span>
                                    <span id="s2-load-val" class="loss-legend-value">0</span>
                                </div>
                                <div class="loss-summary-item">
                                    <span class="loss-legend-dot" style="background:#d90429;"></span>
                                    <span class="loss-legend-label">Stop Time</span>
                                    <span id="s2-stop-val" class="loss-legend-value">0</span>
                                </div>
                                <div class="loss-summary-item">
                                    <span class="loss-legend-dot" style="visibility:hidden;"></span>
                                    <span class="loss-legend-label">Working Time</span>
                                    <span id="s2-work-val" class="loss-legend-value">0</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr style="border:none;border-top:1px solid rgba(255,255,255,0.15);margin:2px 0;">

                    <!-- SHIFT 3 -->
                    <div class="loss-line-wrapper">
                        <div style="display:flex; flex-direction:row; align-items:center; gap:10px; flex:1 1 0; min-height:0;">
                            <b class="loss-line-badge">S3</b>
                            <div class="timeline-container">
                                <div class="timeline-track-wrapper">
                                    <div id="timeline-track-s3" class="timeline-track">
                                        <div id="timeline-progress-s3" class="timeline-progress"></div>
                                    </div>
                                    <div class="timeline-minutes" id="timeline-minutes-s3"></div>
                                </div>
                                <div class="timeline-hours" id="timeline-hours-s3"></div>
                            </div>
                            <div class="loss-summary-right">
                                <div class="loss-summary-item">
                                    <span class="loss-legend-dot" style="background:#4F86F3;"></span>
                                    <span class="loss-legend-label">Load Time</span>
                                    <span id="s3-load-val" class="loss-legend-value">0</span>
                                </div>
                                <div class="loss-summary-item">
                                    <span class="loss-legend-dot" style="background:#d90429;"></span>
                                    <span class="loss-legend-label">Stop Time</span>
                                    <span id="s3-stop-val" class="loss-legend-value">0</span>
                                </div>
                                <div class="loss-summary-item">
                                    <span class="loss-legend-dot" style="visibility:hidden;"></span>
                                    <span class="loss-legend-label">Working Time</span>
                                    <span id="s3-work-val" class="loss-legend-value">0</span>
