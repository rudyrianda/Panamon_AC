                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        let donutChart = null, paChart = null;

        document.getElementById('sl-duration').addEventListener('input', function () {
            document.getElementById('lbl-duration').textContent = this.value + ' hrs';
        });
        document.getElementById('sl-rep').addEventListener('input', function () {
            document.getElementById('lbl-rep').textContent = this.value + ' min';
        });
        document.getElementById('mdp-machine-select').addEventListener('change', function () {
            if (this.value) loadDetail(this.value);
        });

        async function loadMachineData() {
            const month = document.getElementById('filterMonth').value;
            const year = document.getElementById('filterYear').value;
            try {
                const resList = await fetch('/api/machine/list', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                const list = await resList.json();
                const sel = document.getElementById('mdp-machine-select');
                sel.innerHTML = '<option value="">-- Select --</option>';
                if (Array.isArray(list)) {
                    list.forEach(m => {
                        const o = document.createElement('option');
                        o.value = o.textContent = m.machineName;
                        sel.appendChild(o);
                    });
                    if (list.length) { sel.value = list[0].machineName; loadDetail(list[0].machineName); }
                }
            } catch (e) { console.error(e); }
        }

        async function loadDetail(name) {
            const month = document.getElementById('filterMonth').value;
            const year = document.getElementById('filterYear').value;
            try {
                const res = await fetch(`/api/machine/efficiency?month=${month}&year=${year}`, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                const data = await res.json();
                const m = Array.isArray(data) ? data.find(x => x.machineName === name) : null;

                document.getElementById('mdp-model').textContent = m?.modelName || '—';
                setText('mdp-production', m?.production ?? '0');
                setText('mdp-plan', m?.plan ?? '—');
                setText('mdp-actual', m?.actual ?? '—');
                setText('mdp-ng', m?.totalNg ?? '0');

                const diff = (m?.actual != null && m?.plan != null) ? m.actual - m.plan : null;
                const diffEl = document.getElementById('mdp-diff');
                diffEl.textContent = diff != null ? diff : '—';
                diffEl.className = 'stat-val' + (diff != null && diff < 0 ? ' neg' : diff != null && diff > 0 ? ' pos' : '');
                setText('mdp-remaining', m?.remaining ?? '—');

                const oee = m?.oee ?? 0, ability = m?.ability ?? 0;
                const op = m?.operatingRatio ?? 0, quality = m?.quality ?? 0;

                document.getElementById('donut-val').textContent = oee + '%';
                document.getElementById('leg-oee').textContent = oee + '%';
                document.getElementById('leg-ability').textContent = ability + '%';
                document.getElementById('leg-op').textContent = op + '%';
                document.getElementById('leg-quality').textContent = quality + '%';

                renderDonut(oee, op, ability, quality);
                renderPA(m);
                renderShifts(m);
                renderGantt(m);
            } catch (e) { console.error(e); }
        }

        function setText(id, val) { document.getElementById(id).textContent = val; }

        function isLightMode() { return document.body.classList.contains('light-mode'); }

        function getChartColors() {
            if (isLightMode()) {
                return {
                    tickColor: 'rgba(26,26,46,0.9)', gridColor: 'rgba(0,0,0,0.07)',
                    planLine: 'rgba(26,26,46,0.25)', actualLine: '#185FA5',
                    actualFill: 'rgba(24,95,165,0.12)', donutBorder: 'rgba(0,0,0,0.06)',
                    tooltipBg: 'rgba(255,255,255,0.92)', tooltipTitle: '#1a1a2e',
                    tooltipBody: 'rgba(26,26,46,0.75)', tooltipBorder: 'rgba(0,0,0,0.12)',
                };
            } else {
                return {
                    tickColor: 'rgba(255,255,255,0.9)', gridColor: 'rgba(255,255,255,0.05)',
                    planLine: 'rgba(255,255,255,0.3)', actualLine: '#63b3ed',
                    actualFill: 'rgba(99,179,237,0.15)', donutBorder: 'rgba(255,255,255,0.15)',
                    tooltipBg: 'rgba(0,0,0,0.75)', tooltipTitle: '#fff',
                    tooltipBody: 'rgba(255,255,255,0.75)', tooltipBorder: 'rgba(255,255,255,0.1)',
                };
            }
        }

        function renderDonut(oee, op, ability, quality) {
            const c = getChartColors();
            const ctx = document.getElementById('donutChart').getContext('2d');
            if (donutChart) donutChart.destroy();
            donutChart = new Chart(ctx, {
                type: 'doughnut',
                data: { datasets: [{ data: [oee, op, ability, quality], backgroundColor: ['#38a169','#e53e3e','#ed8936','#4299e1'], borderWidth: 3, borderColor: c.donutBorder, circumference: 270, rotation: -135, cutout: '58%' }] },
                options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { display: false }, tooltip: { enabled: false } }, animation: { duration: 600 } }
            });
        }

        function renderPA(m) {
            const c = getChartColors();
            const ctx = document.getElementById('planActualChart').getContext('2d');
            const totalPlan = m?.plan ?? 448, totalActual = m?.actual ?? 420;
            const pts = 30, labels = [], plan = [], actual = [];
            for (let i = 0; i <= pts; i++) {
                const t = 7 + i * (9 / pts);
                labels.push(('0' + Math.floor(t)).slice(-2) + ':' + ('0' + Math.round((t % 1) * 60)).slice(-2));
                plan.push(Math.round(totalPlan / pts * i));
                actual.push(Math.max(0, Math.round(totalActual / pts * i + (Math.random() - .45) * 8)));
            }
            if (paChart) paChart.destroy();
            paChart = new Chart(ctx, {
                type: 'line',
                data: { labels, datasets: [
                    { label: 'Plan', data: plan, borderColor: c.planLine, borderWidth: 1.5, borderDash: [5,4], pointRadius: 0, fill: false, tension: .3 },
                    { label: 'Actual', data: actual, borderColor: c.actualLine, backgroundColor: c.actualFill, borderWidth: 2.5, pointRadius: 0, fill: true, tension: .4 }
                ]},
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { mode: 'index', intersect: false, backgroundColor: c.tooltipBg, titleColor: c.tooltipTitle, bodyColor: c.tooltipBody, borderColor: c.tooltipBorder, borderWidth: 1 } },
                    scales: {
                        x: { ticks: { font: { size: 11 }, color: c.tickColor, maxTicksLimit: 10 }, grid: { color: c.gridColor } },
                        y: { ticks: { font: { size: 11 }, color: c.tickColor }, grid: { color: c.gridColor } }
                    },
                    animation: { duration: 400 }
                }
            });
        }

        function renderShifts(m) {
            [['s1', m?.shift1Working??307, m?.shift1Stop??44, m?.shift1Load??263],
             ['s2', m?.shift2Working??0,   m?.shift2Stop??0,  m?.shift2Load??0],
             ['s3', m?.shift3Working??0,   m?.shift3Stop??0,  m?.shift3Load??0]
            ].forEach(([p, w, s, l]) => {
                document.getElementById(p+'-work').textContent = w;
                document.getElementById(p+'-stop').textContent = s;
                document.getElementById(p+'-load').textContent = l;
            });
        }

        function renderGantt(m) {
            const shifts = [
                { id: 's1', work: m?.shift1Working??307, stop: m?.shift1Stop??44, load: m?.shift1Load??263, hourLabels: ['07','08','09','10','11','12','13','14','15'] },
                { id: 's2', work: m?.shift2Working??0,   stop: m?.shift2Stop??0,  load: m?.shift2Load??0,   hourLabels: ['15','16','17','18','19','20','21','22','23'] },
                { id: 's3', work: m?.shift3Working??0,   stop: m?.shift3Stop??0,  load: m?.shift3Load??0,   hourLabels: ['23','00','01','02','03','04','05','06','07'] }
            ];

            shifts.forEach(s => {
                document.getElementById(`${s.id}-work-val`).textContent = s.work;
                document.getElementById(`${s.id}-stop-val`).textContent = s.stop;
                document.getElementById(`${s.id}-load-val`).textContent = s.load;

                const track = document.getElementById(`timeline-track-${s.id}`);
                const progress = document.getElementById(`timeline-progress-${s.id}`);
                track.innerHTML = '';
                track.appendChild(progress);

                const total = s.work + s.stop;
                const loadPercent = total > 0 ? (s.work / total) * 100 : 0;
                const stopPercent = total > 0 ? (s.stop / total) * 100 : 0;
                progress.style.width = loadPercent + '%';

                const stopDiv = document.createElement('div');
                stopDiv.className = 'loss-marker';
                stopDiv.style.left = loadPercent + '%';
                stopDiv.style.width = stopPercent + '%';
                track.appendChild(stopDiv);

                const hourWrap = document.getElementById(`timeline-hours-${s.id}`);
                hourWrap.innerHTML = '';
                s.hourLabels.forEach(h => {
                    const span = document.createElement('span');
                    span.textContent = h + ':00';
                    hourWrap.appendChild(span);
                });
            });
        }

        document.addEventListener('DOMContentLoaded', loadMachineData);
        document.getElementById('btnSearch').addEventListener('click', loadMachineData);
        document.getElementById('btn-set').addEventListener('click', () => {
            const n = document.getElementById('mdp-machine-select').value;
            if (n) loadDetail(n);
        });
    </script>
}
