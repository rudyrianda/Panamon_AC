                <div class="card-body p-0 shift-card">
                    <div class="shift-block">
                        <div class="shift-lbl">Shift #1</div>
                        <div class="shift-row"><span>Working Time</span><span id="s1-work">—</span></div>
                        <div class="shift-row"><span>Stop Time</span><span id="s1-stop">—</span></div>
                        <div class="shift-row"><span>Load Time</span><span id="s1-load">—</span></div>
                    </div>
                    <div class="shift-block">
                        <div class="shift-lbl">Shift #2</div>
                        <div class="shift-row"><span>Working Time</span><span id="s2-work">—</span></div>
                        <div class="shift-row"><span>Stop Time</span><span id="s2-stop">—</span></div>
                        <div class="shift-row"><span>Load Time</span><span id="s2-load">—</span></div>
                    </div>
                    <div class="shift-block">
                        <div class="shift-lbl">Shift #3</div>
                        <div class="shift-row"><span>Working Time</span><span id="s3-work">—</span></div>
                        <div class="shift-row"><span>Stop Time</span><span id="s3-stop">—</span></div>
                        <div class="shift-row"><span>Load Time</span><span id="s3-load">—</span></div>
                    </div>
                    <div class="shift-block">
                        <div class="shift-lbl">Shift Status</div>
                        <div class="shift-status-row">
                            <button class="status-btn run">RUN</button>
                            <button class="status-btn stop">STOP</button>
