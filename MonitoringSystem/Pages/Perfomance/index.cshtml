<div class="row mx-3">
    <form method="post" asp-page-handler="OnPost" class="w-100 mb-3">
        <div class="row">
            <div class="col-5 d-flex gap-2 align-items-center">
                <label class="fw-bold fs-5 perf-label">LINE</label>
                <select asp-for="MachineCode" class="form-select border-2 fs-5 fw-bold perf-select" id="MachineCode">
                    <option value="MCH1-01">CU Line</option>
                    <option value="MCH1-02">CS Line</option>
                </select>
            </div>
            <div class="col-5 d-flex gap-2 align-items-center">
                <label class="fw-bold fs-5 perf-label">DATE</label>
                <input asp-for="SelectedDate" type="date" class="form-control border-2 fs-5 fw-bold w-100 perf-date"
                       value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col align-items-center">
                <button type="submit" class="btn fs-5 fw-semibold btn-perf">FILTER</button>
            </div>
        </div>
    </form>

    <div class="col-5">
        <div class="text-center table-responsive perf-card p-0 m-0 @(Model.SelectedDate != DateTime.Now.Date ? "" : "refreshDailyData")">
            <table class="table rounded-2 overflow-hidden p-0 m-0">
                <tbody>
                    <tr>
                        <td colspan="2" class="perf-th fs-4 fw-bold w-50 py-3">PLAN</td>
                        <td class="perf-td fs-4 fw-bold w-50 py-3">@planProd</td>
                    </tr>
                    <tr>
                        <td colspan="2" class="perf-th fs-4 fw-bold w-50 py-3">TARGET</td>
                        <td class="perf-td fs-4 fw-bold w-50 py-3">@targetProd</td>
                    </tr>
                    <tr>
                        <td colspan="2" class="perf-th fs-4 fw-bold w-50 py-3">ACTUAL</td>
                        <td class="perf-td fs-4 fw-bold w-50 py-3">@actualProd</td>
                    </tr>
                    <tr>
                        <td colspan="2" class="perf-th fs-4 fw-bold w-50 py-3">DIFFERENCE</td>
                        <td class="perf-td fs-4 fw-bold w-50 py-3 @(differenceProd > 0 ? "" : "text-danger")">@differenceProd</td>
                    </tr>
                    <tr>
                        <td colspan="2" class="perf-th fs-4 fw-bold w-50 py-3">EFFICIENCY</td>
                        <td class="perf-td fs-4 fw-bold w-50 py-3">
                            @(efficiencyValue > 0 ? efficiencyValue : 0) %
                        </td>
                    </tr>
                    <tr>
                        <td rowspan="2" class="perf-th align-middle border border-end fs-4 fw-bold py-3">TAKE TIME</td>
                        <td class="perf-th fs-4 fw-bold py-3">PLAN</td>
                        <td class="perf-td fs-4 fw-bold py-3">@planTaktTime s</td>
                    </tr>
                    <tr>
                        <td class="perf-th fs-4 fw-bold py-3">ACT</td>
                        <td class="perf-td fs-4 fw-bold py-3">@(efficiencyMetrics.ActTaktTime > 0 ? efficiencyMetrics.ActTaktTime : 0) s</td>
                    </tr>
                    <tr>
                        <td colspan="2" class="perf-th fs-4 fw-bold w-50 py-3">PASS THROUGH RATIO</td>
                        <td class="perf-td fs-4 fw-bold w-50 py-3">@defectRatio %</td>
                    </tr>
                    <tr>
                        <td colspan="2" class="perf-th fs-4 fw-bold w-50 py-3">WORKING TIME</td>
                        <td class="perf-td fs-4 fw-bold w-50 py-3">@(workingTime > 0 ? workingTime : 0) min</td>
                    </tr>
                    <tr>
                        <td colspan="2" class="perf-th fs-4 fw-bold w-50 py-3">LOSS TIME</td>
                        <td class="perf-td fs-4 fw-bold w-50 py-3">@totalLossTime min</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="col-7">
        <div class="perf-panel rounded-3 mb-3" style="height: 300px; contain: layout style;">
            <div class="row">
                <label class="fs-2 text-center fw-bolder perf-panel-title">REALTIME EFFICIENCY</label>
            </div>
            <div class="row d-flex justify-content-center mx-2" style="height: 240px;">
                <canvas id="RealtimeChart"></canvas>
            </div>
        </div>

        <div class="overflow-y-auto text-center table-responsive perf-panel p-0 m-0 @(Model.SelectedDate != DateTime.Now.Date ? "" : "refreshHourlyAchievement")" style="height:378px; contain: layout style;">
            <div class="row p-0 m-0">
                <label class="fs-2 text-center fw-bolder p-0 m-0 perf-panel-title">HOURLY ACHIEVEMENT</label>
            </div>
            <div class="overflow-y-auto row p-0 m-0">
                <table class="table border-2 p-0 m-0 fs-4 overflow-y-auto perf-hourly-table">
                    <thead>
                        <tr>
                            <th scope="col" style="background-color: rgba(61, 121, 176, 0.82) !important; color: #ffffff !important;">TIME</th>
                            <th scope="col" style="background-color: rgba(61, 121, 176, 0.82) !important; color: #ffffff !important;">MODEL</th>
                            <th scope="col" style="background-color: rgba(61, 121, 176, 0.82) !important; color: #ffffff !important;">PLAN</th>
                            <th scope="col" style="background-color: rgba(61, 121, 176, 0.82) !important; color: #ffffff !important;">ACTUAL</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (sortedProdAchieve.Count > 0)
                        {
                            var previousTime = "";
                            var previousModel = "";

                            for (int i = 0; i < sortedProdAchieve.Count; i++)
                            {
                                        <tr>
                                    @if (previousTime != sortedProdAchieve[i].Time)
                                    {
                                                    <td rowspan="@timeCounts[sortedProdAchieve[i].Time]" class="fw-bold">
                                            @(sortedProdAchieve[i].Time ?? "00:00 - 00:00")
                                                    </td>
                                        previousTime = sortedProdAchieve[i].Time;
                                    }
                                            <td class="fw-bold">@(sortedProdAchieve[i].Model ?? "NULL")</td>
                                            <td class="fw-bold">
                                        @{
                                            var planPerHour = CalculatePlanPerHour(
                                                sortedProdAchieve[i].Model,
                                                previousModel,
                                                sortedProdAchieve[i].StartTime,
                                                sortedProdAchieve[i].EndTime,
                                                currentTime,
                                                currentDate,
                                                sortedProdAchieve[i].SUT,
                                                listRestTime
                                            );
                                            previousModel = sortedProdAchieve[i].Model;
                                        }
                                        @planPerHour
                                            </td>
                                            <td class="fw-bold">@(sortedProdAchieve[i].Actual != null ? sortedProdAchieve[i].Actual : 1)</td>
                                        </tr>
                            }
                        }
                        else
                        {
                                <tr>
                                    <td colspan="4" style="padding: 8px; text-align: center;">There is no actual data entered</td>
                                </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
        <script>
            let labelData          = @(Html.Raw(System.Text.Json.JsonSerializer.Serialize(efficiencyData.Labels)));
            let efficiencyDataPoints = @(Html.Raw(System.Text.Json.JsonSerializer.Serialize(efficiencyData.CumulativeEfficiency)));

            const isLightMode = document.body.classList.contains('light-mode');
            const gridColor   = isLightMode ? 'rgba(0,0,0,0.08)'      : 'rgba(255,255,255,0.10)';
            const tickColor   = isLightMode ? '#1a1a2e'                : 'rgba(220,228,240,0.75)';
            const legendColor = isLightMode ? '#1a1a2e'                : 'rgba(220,228,240,0.85)';

            const ctx = document.getElementById('RealtimeChart').getContext('2d');
            const realtimeChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labelData,
                    datasets: [{
                        label: 'Efficiency (%)',
                        data: efficiencyDataPoints,
                        borderColor: 'rgba(75, 192, 192, 1)',
                        backgroundColor: 'rgba(75, 192, 192, 0.2)',
                        fill: false,
                        tension: 0.1,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: { duration: 400 },
                    plugins: {
                        legend: {
                            display: true,
                            labels: { color: legendColor, font: { weight: '600' } }
                        },
                    },
                    scales: {
                        x: { ticks: { color: tickColor }, grid: { color: gridColor } },
                        y: {
                            beginAtZero: true,
                            max: 120,
                            ticks: { color: tickColor, callback: function(value) { return value + '%'; } },
                            grid: { color: gridColor }
                        }
                    }
                },
            });

            window.myChart = realtimeChart;

            async function fetchUpdatedChartData() {
                try {
                    const machineCode  = document.getElementById('MachineCode').value;
                    const selectedDate = document.querySelector('input[name="SelectedDate"]').value;
                    const response     = await fetch(`?handler=UpdatedData&machineCode=${machineCode}&selectedDate=${selectedDate}`);

                    if (!response.ok) throw new Error(`HTTP error! Status: ${response.status}`);
                    const data = await response.json();
                    if (!data || !data.Labels || !data.Efficiency) throw new Error("Incomplete data received.");

                    window.myChart.data.labels            = data.Labels;
                    window.myChart.data.datasets[0].data  = data.Efficiency;
                    window.myChart.update();
                } catch (error) {
                    console.error("Failed to fetch updated data:", error.message);
                }
            }

            // ✅ OPTIMASI: interval 15 detik — lebih ringan dari 10 detik
            setInterval(fetchUpdatedChartData, 15000);
        </script>
}
