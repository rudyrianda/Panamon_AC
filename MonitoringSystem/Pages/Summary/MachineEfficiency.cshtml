        html.light-mode .filter-content .form-control { background-color:rgba(255,255,255,0.65)!important;border-color:rgba(0,0,0,0.25)!important;color:#1a1a2e!important; }
        html.light-mode .filter-content .form-select,html.light-mode .filter-content .form-select-sm { background-color:rgba(255,255,255,0.5)!important;border-color:rgba(0,0,0,0.2)!important;color:#1a1a2e!important;background-image:url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%231a1a2e' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e")!important; }
        html.light-mode .filter-content .form-select option,html.light-mode .filter-content .form-select-sm option { background-color:#ffffff!important;color:#1a1a2e!important; }
        html.light-mode .filter-content .form-select:focus,html.light-mode .filter-content .form-select-sm:focus,html.light-mode .filter-content .form-control:focus { background-color:rgba(255,255,255,0.9)!important;border-color:rgba(61,121,176,0.5)!important;color:#1a1a2e!important;box-shadow:0 0 0 0.2rem rgba(61,121,176,0.15)!important; }
        html.light-mode .filter-content .btn-primary { background-color:rgba(61,121,176,0.85)!important;border-color:rgba(61,121,176,0.9)!important;color:#ffffff!important; }
        html.light-mode .filter-content .btn-primary:hover { background-color:rgba(35,90,150,0.95)!important;color:#ffffff!important; }
        html.light-mode .filter-content .btn-danger { background-color:rgba(180,40,50,0.85)!important;border-color:rgba(200,60,70,0.9)!important;color:#ffffff!important; }
        html.light-mode .filter-content .btn-danger:hover { background-color:rgba(150,25,35,0.95)!important;color:#ffffff!important; }
        .filter-content .btn-success { background-color:rgba(18,90,48,0.92);border:2px solid rgba(129,199,132,0.85);color:rgba(129,199,132,1); }
