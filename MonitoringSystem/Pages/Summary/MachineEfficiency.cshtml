        html.light-mode .filter-content .btn-success { background-color:rgba(25,135,84,0.88)!important;border:2px solid rgba(25,135,84,0.9)!important;color:#ffffff!important; }
        html.light-mode .filter-content .btn-success:hover { background-color:rgba(18,108,66,0.95)!important;color:#ffffff!important; }
        .card { margin:5px 12px 8px;background:rgba(255,255,255,0.20)!important;border-radius:12px;border:2px solid rgba(255,255,255,0.3)!important;box-shadow:0 4px 16px rgba(0,0,0,0.2);color:#ffffff!important; }
