        .filter-content .btn-primary { background-color:rgba(8,65,150,0.95);border:2px solid rgba(100,181,246,1);color:rgba(100,181,246,1); }
        .filter-content .btn-primary:hover { background-color:rgba(5,45,110,1);border-color:rgba(144,202,249,1);color:rgba(144,202,249,1); }
