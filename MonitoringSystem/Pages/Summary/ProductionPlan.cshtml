        <div class="card">
            <form id="form-production-plan" method="post" asp-page-handler="InsertProductionRecord">
                <input type="hidden" name="FilterMachineCode" value="@Model.FilterMachineCode" />
                <input type="hidden" name="TargetDate" value="@Model.CurrentDate.ToString("yyyy-MM-dd")" />
                <div class="card-header">
                    <div class="row"> 
                        <div class="col-6">
                          <div class="card text-center">
                                <p class="pt-2 fs-7">Date :</p>
                                <p class="fs-4 fw-bold">
                                    @Model.CurrentDate.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("en-US"))
                                </p>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="card text-center">
                                <p class="pt-2 fs-7">Total Quantity :</p>
                                <p class="fs-4 fw-bold">@(Model.GrandTotal != null ? Model.GrandTotal : "0")</p>
                            </div>
                        </div>
                    </div>
                </div>
                <table class="table table-bordered">
                    <thead>
                        <tr class="text-center">
                            <th colspan="3">Original</th>
                            <th colspan="8">Current</th>
                             <th rowspan="3">Action</th>
                        </tr>

                        <tr class="text-center">
                            <th rowspan="2">No</th>
                            <th rowspan="2">Model Name</th>
                            <th rowspan="2">Quantity</th>
                            <th rowspan="2">Model Name</th>

                            <th colspan="2">Plan</th>

                            <th colspan="2">No Of Direct Worker</th>

                            <th rowspan="2">Shift</th>
                            <th rowspan="2">Qty/Hour</th>
                            <th rowspan="2">Hour</th>

                        </tr>

                        <tr class="text-center">
                            <th>Quantity</th>
                            <th>Overtime</th>
                            <th>Normal</th>
                            <th>Overtime</th>
                        </tr>
                    </thead>

                    <tbody id="production-table-body">
                    @{
                        int minRows = 5;
                        int sapCount = Model.listSapPlans.Count;
                        int dataCount = Model.listRecords.Count;
                        int totalRows = Math.Max(Math.Max(sapCount, dataCount), minRows);
                        // Track records yang sudah ditampilkan
                        var usedRecordIds = new HashSet<int>();
                    }

                    @for (int i = 0; i < totalRows; i++)
                    {
                        var sapPlan = sapCount > i ? Model.listSapPlans[i] : null;
                        var record = dataCount > i ? Model.listRecords[i] : null;

                        // Pastikan record belum dipakai di row sebelumnya
                        if (record != null && usedRecordIds.Contains(record.Id))
                        {
                            record = Model.listRecords.FirstOrDefault(r => !usedRecordIds.Contains(r.Id));
                        }
                        if (record != null) usedRecordIds.Add(record.Id);

                        int? originalQty = sapPlan != null ? (sapPlan.SapPlanNormal + sapPlan.SapPlanOvertime) : (int?)null;

                <tr>
                    <th scope="row" class="text-center align-middle row-number">@(i + 1)</th>

                    <td>
                        <input type="hidden" name="OriginalModelName[@i]" value="@(sapPlan?.ModelName)" />
                        <input disabled type="text" class="form-control"
                               value="@(sapPlan?.ModelName)" placeholder="-" />
                    </td>

                    <td>
                        <input type="hidden" name="OriginalQuantity[@i]" value="@(originalQty?.ToString())" />
                        <input disabled type="text" class="form-control"
                               value="@(originalQty?.ToString())" placeholder="-" />
