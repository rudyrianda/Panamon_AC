    @page
    @model MonitoringSystem.Pages.Shared.ProductionPlanModel
    @{
        ViewData["Title"] = "Production Plan";
        string formattedDate = DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("en-US"));
    }

    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"]</title>
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link href="~/css/Sidebar.css" rel="stylesheet" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

        @* SweetAlert2 *@
        <link rel="stylesheet" href="~/css/sweetalert2.css" />

        <style>
            /* Pastikan parent container punya position relative */
            .input-group.position-relative {
                position: relative !important;
            }

            /* ===== DROPDOWN CUSTOM - DARK MODE DEFAULT ===== */
            .dropdown.custom-dropdown {
                position: absolute !important;
                top: calc(100% + 2px) !important;
                left: 0 !important;
                right: 0 !important;
                width: 100% !important;
                z-index: 99999 !important;
                display: none;
                background-color: rgba(30, 40, 60, 0.98) !important;
                border: 2px solid rgba(100, 181, 246, 0.5) !important;
                border-radius: 8px;
                box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
                max-height: 200px;
                overflow-y: auto;
                margin-top: 0;
            }

            .dropdown.custom-dropdown div {
                padding: 10px;
                cursor: pointer;
                color: #ffffff !important;
                background-color: transparent !important;
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            }

            .dropdown.custom-dropdown div:hover {
                background-color: rgba(100, 181, 246, 0.2) !important;
                color: #ffffff !important;
            }

            .dropdown.custom-dropdown div:last-child {
                border-bottom: none;
            }

            .dropdown.custom-dropdown::-webkit-scrollbar { width: 6px; }
            .dropdown.custom-dropdown::-webkit-scrollbar-track { background: rgba(255,255,255,0.05); border-radius: 3px; }
            .dropdown.custom-dropdown::-webkit-scrollbar-thumb { background: rgba(100,181,246,0.3); border-radius: 3px; }
            .dropdown.custom-dropdown::-webkit-scrollbar-thumb:hover { background: rgba(100,181,246,0.5); }

            td .dropdown.custom-dropdown {
                position: absolute !important;
                top: calc(100% + 2px) !important;
                left: 0 !important;
                width: 100% !important;
                z-index: 99999 !important;
            }

            /* ===== LIGHT MODE - DROPDOWN ===== */
            body.light-mode .dropdown.custom-dropdown {
                background-color: rgba(245, 250, 255, 0.98) !important;
                border: 2px solid rgba(61, 121, 176, 0.4) !important;
                box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12) !important;
            }

            body.light-mode .dropdown.custom-dropdown div {
                color: #1a1a2e !important;
                border-bottom: 1px solid rgba(0, 0, 0, 0.07) !important;
            }

            body.light-mode .dropdown.custom-dropdown div:hover {
                background-color: rgba(61, 121, 176, 0.12) !important;
                color: #1a1a2e !important;
            }

            body.light-mode .dropdown.custom-dropdown::-webkit-scrollbar-track {
                background: rgba(0, 0, 0, 0.04);
            }

            body.light-mode .dropdown.custom-dropdown::-webkit-scrollbar-thumb {
                background: rgba(61, 121, 176, 0.25);
            }

            body.light-mode .dropdown.custom-dropdown::-webkit-scrollbar-thumb:hover {
                background: rgba(61, 121, 176, 0.45);
            }

            /* ===== FILTER AREA ===== */
            .filter-area-with-lines {
                position: relative;
                padding: 1px 0;
                margin-bottom: -63px !important;
                margin-top: -20px;
                min-height: 10px;
                width: calc(100% - 14px);
                margin-left: 7px;
                margin-right: 7px;
            }

            .panamon-bottom-line,
            .panamon-bottomm-line {
                position: absolute !important;
                left: -13px !important;
                right: -13px !important;
                height: 2px !important;
                background: rgba(255, 255, 255, 0.04) !important;
                z-index: 999 !important;
                pointer-events: none !important;
                display: block !important;
            }

            .panamon-bottom-line { top: 0 !important; border-top: 2px solid rgba(255, 255, 255, 0.08) !important; }
            .panamon-bottomm-line { bottom: 0 !important; border-bottom: 2px solid rgba(255, 255, 255, 0.08) !important; }

            /* ===== LIGHT MODE - PANAMON LINES ===== */
            body.light-mode .panamon-bottom-line {
                border-top-color: rgba(0, 0, 0, 0.10) !important;
                background: rgba(0, 0, 0, 0.03) !important;
            }

            body.light-mode .panamon-bottomm-line {
                border-bottom-color: rgba(0, 0, 0, 0.10) !important;
                background: rgba(0, 0, 0, 0.03) !important;
            }

            .filter-content {
                position: relative;
                z-index: 2;
                padding: 6px 0;
                border-radius: 15px;
                margin-left: -8px;
                margin-right: 7px;
            }

            .filter-content .form-select.selected { font-weight: 700 !important; }

            .filter-content .form-select,
            .filter-content .form-control {
                height: 28px;
                padding: 0 22px 0 8px;
                font-size: 12px;
                line-height: 20px;
                border-radius: 999px;
                background-color: rgba(255, 255, 255, 0.05);
                border: 2px solid rgba(255, 255, 255, 0.5);
                color: #ffffff;
                text-align: center;
                appearance: none;
                -webkit-appearance: none;
                -moz-appearance: none;
                padding-top: 0;
                padding-bottom: 0;
                vertical-align: middle;
            }

            .filter-content .form-select {
                height: 28px;
                padding: 0 !important;
                padding-left: 12px !important;
                padding-right: 28px !important;
                font-size: 12px;
                line-height: 16px;
                border-radius: 999px;
                background-color: rgba(255, 255, 255, 0.05);
                border: 2px solid rgba(255, 255, 255, 0.5);
                color: #ffffff;
                background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23ffffff' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
                background-repeat: no-repeat;
                background-position: right 8px center;
                background-size: 10px 10px;
            }

            .filter-content .form-select option {
                background-color: rgb(30, 40, 60);
                color: #ffffff;
                font-size: 12px;
                padding: 8px;
            }

            .filter-content .form-select-sm {
                height: 28px;
                padding: 0 !important;
                padding-left: 12px !important;
                padding-right: 28px !important;
                font-size: 12px;
                line-height: 16px;
                border-radius: 999px;
                background-color: rgba(255, 255, 255, 0.05);
                border: 2px solid rgba(255, 255, 255, 0.5);
                color: #ffffff;
                text-align: center;
                appearance: none;
                -webkit-appearance: none;
                -moz-appearance: none;
                background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23ffffff' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
                background-repeat: no-repeat;
                background-position: right 8px center;
                background-size: 10px 10px;
            }

            .filter-content .form-select-sm option {
                background-color: rgb(30, 40, 60);
                color: #ffffff;
                font-size: 12px;
                padding: 8px;
            }

            .filter-content .form-select-sm.selected { font-weight: 700 !important; }

            .filter-content .form-select:focus,
            .filter-content .form-control:focus {
                background-color: rgba(255, 255, 255, 0.20);
                border-color: rgba(255, 255, 255, 0.3);
                color: #ffffff;
                box-shadow: 0 0 0 0.2rem rgba(255, 255, 255, 0.1);
            }

            .filter-content label {
                color: rgba(255, 255, 255, 0.85);
                font-size: 12px;
                line-height: 20px;
            }

            .filter-content .btn {
                height: 28px;
                min-height: 20px;
                padding: 0 12px;
                font-size: 12px;
                line-height: 20px;
                border-radius: 999px !important;
                font-weight: 600;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .filter-content .btn-primary {
                background-color: rgba(8, 65, 150, 0.95);
                border: 2px solid rgba(100, 181, 246, 1);
                color: rgba(100, 181, 246, 1);
            }

            .filter-content .btn-primary:hover {
                background-color: rgba(5, 45, 110, 1);
                border-color: rgba(144, 202, 249, 1);
                color: rgba(144, 202, 249, 1);
            }

            .filter-content .btn-danger {
                background-color: rgba(140, 30, 40, 0.95);
                border: 2px solid rgba(239, 154, 154, 1);
                color: rgba(239, 154, 154, 1);
            }

            .filter-content .btn-danger:hover {
                background-color: rgba(110, 20, 30, 1);
                border-color: rgba(244, 143, 177, 1);
                color: rgba(244, 143, 177, 1);
            }

            /* ===== LIGHT MODE - FILTER ===== */
            body.light-mode .filter-content label { color: #1a1a2e !important; }

            body.light-mode .filter-content .form-control {
                background-color: rgba(255, 255, 255, 0.65) !important;
                border-color: rgba(0, 0, 0, 0.25) !important;
                color: #1a1a2e !important;
            }

            body.light-mode .filter-content .form-select,
            body.light-mode .filter-content .form-select-sm {
                background-color: rgba(255, 255, 255, 0.5) !important;
                border-color: rgba(0, 0, 0, 0.2) !important;
                color: #1a1a2e !important;
                background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%231a1a2e' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e") !important;
            }

            body.light-mode .filter-content .form-select option,
            body.light-mode .filter-content .form-select-sm option {
                background-color: #ffffff !important;
                color: #1a1a2e !important;
            }

            body.light-mode .filter-content .btn-primary {
                background-color: rgba(61, 121, 176, 0.85) !important;
                border-color: rgba(61, 121, 176, 0.9) !important;
                color: #ffffff !important;
            }

            body.light-mode .filter-content .btn-primary:hover {
                background-color: rgba(35, 90, 150, 0.95) !important;
                color: #ffffff !important;
            }

            body.light-mode .filter-content .btn-danger {
                background-color: rgba(180, 40, 50, 0.85) !important;
                border-color: rgba(200, 60, 70, 0.9) !important;
                color: #ffffff !important;
            }

            /* ===== TABLE SPACING ===== */
            .table tbody td,
            .table tbody th {
                padding: 3px 5px;
                vertical-align: middle;
            }

            .table td input.form-control { padding: 6px 10px; }
            .table td .d-flex { gap: 4px; }
            .table .form-check { margin-bottom: 0; }

            /* ===== CARD - DARK MODE DEFAULT ===== */
            .card {
                margin-left: 12px;
                margin-right: 12px;
                margin-top: 15px;
                margin-bottom: 8px;
                background: rgba(255, 255, 255, 0.20) !important;
                border-radius: 12px;
                border: 2px solid rgba(255, 255, 255, 0.3) !important;
                box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
                color: #ffffff !important;
            }

            .card * { color: #ffffff !important; }
            .card .btn-warning, .card .btn-warning * { color: #000000 !important; }

            .card-header {
                background: transparent !important;
                border-bottom: 1px solid rgba(255, 255, 255, 0.2) !important;
                padding: 12px;
            }

            .card-header .card {
                background: rgba(30, 40, 60, 0.9) !important;
                border: 2px solid rgba(100, 181, 246, 0.5) !important;
                color: #ffffff !important;
                border-radius: 8px;
                padding: 8px;
            }

            .card-header .card p { color: #ffffff !important; margin-bottom: 4px; }

            /* ===== LIGHT MODE - CARD ===== */
            body.light-mode .card {
                background: rgba(255, 255, 255, 0.55) !important;
                border: 2px solid rgba(200, 215, 235, 0.80) !important;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.10) !important;
                color: #1a1a2e !important;
            }

            body.light-mode .card * { color: #1a1a2e !important; }
            body.light-mode .card .btn-warning, body.light-mode .card .btn-warning * { color: #1a1a2e !important; }
            body.light-mode .card .btn-success, body.light-mode .card .btn-success * { color: #ffffff !important; }
            body.light-mode .card .btn-danger, body.light-mode .card .btn-danger * { color: #ffffff !important; }
            body.light-mode .card .btn-primary, body.light-mode .card .btn-primary * { color: #ffffff !important; }

            body.light-mode .card-header {
                background-color: rgba(255, 255, 255, 0.35) !important;
                border-bottom: 1px solid rgba(0, 0, 0, 0.1) !important;
            }

            body.light-mode .card-header .card {
                background: rgba(230, 240, 255, 0.85) !important;
                border: 2px solid rgba(61, 121, 176, 0.4) !important;
                color: #1a1a2e !important;
            }

            body.light-mode .card-header .card p { color: #1a1a2e !important; }

            /* ===== TABLE - DARK MODE DEFAULT ===== */
            .table {
                background-color: rgba(255, 255, 255, 0.08) !important;
                color: #ffffff !important;
            }

            .table thead th,
            .table > thead > tr > th {
                background-color: rgba(30, 40, 60, 1) !important;
                color: #ffffff !important;
                border-color: rgba(255, 255, 255, 0.3) !important;
                text-align: center !important;
                vertical-align: middle !important;
            }

            .table tbody td,
            .table tbody th {
                background-color: rgba(255, 255, 255, 0.08) !important;
                color: #ffffff !important;
                border-color: rgba(255, 255, 255, 0.3) !important;
            }

            .table tbody input[type="text"],
            .table tbody input[type="number"] { color: #ffffff !important; }

            .table .form-check-label { color: #ffffff !important; }

            .table td input.form-control,
            .table td textarea.form-control {
                background-color: rgba(255, 255, 255, 0.1);
                border: 1px solid rgba(255, 255, 255, 0.3);
                color: #ffffff;
            }

            .table td input.form-control:focus,
            .table td textarea.form-control:focus {
                background-color: rgba(255, 255, 255, 0.15);
                border-color: rgba(100, 181, 246, 0.5);
                color: #ffffff;
            }

            .table td input.form-control::placeholder,
            .table td textarea.form-control::placeholder { color: rgba(255, 255, 255, 0.5); }

            .table td input:disabled {
                background-color: rgba(255, 255, 255, 0.05);
                color: rgba(255, 255, 255, 0.6);
            }

            /* ===== LIGHT MODE - TABLE ===== */
            body.light-mode .table {
                background-color: transparent !important;
                color: #1a1a2e !important;
            }

            body.light-mode .table thead th,
            body.light-mode .table > thead > tr > th {
                background-color: rgba(25, 35, 58, 0.92) !important;
                color: #ffffff !important;
                border-color: rgba(255, 255, 255, 0.25) !important;
            }

            body.light-mode .table tbody td,
            body.light-mode .table tbody th {
                background-color: rgba(255, 255, 255, 0.50) !important;
                color: #1a1a2e !important;
                border-color: rgba(0, 0, 0, 0.07) !important;
            }

            body.light-mode .table tbody input[type="text"],
            body.light-mode .table tbody input[type="number"] { color: #1a1a2e !important; }

            body.light-mode .table .form-check-label { color: #1a1a2e !important; }

            body.light-mode .table td input.form-control,
            body.light-mode .table td textarea.form-control {
                background-color: rgba(255, 255, 255, 0.85) !important;
                border: 1px solid rgba(0, 0, 0, 0.18) !important;
                color: #1a1a2e !important;
            }

            body.light-mode .table td input.form-control:focus,
            body.light-mode .table td textarea.form-control:focus {
                background-color: rgba(255, 255, 255, 0.98) !important;
                border-color: rgba(61, 121, 176, 0.55) !important;
                color: #1a1a2e !important;
            }

            body.light-mode .table td input.form-control::placeholder,
            body.light-mode .table td textarea.form-control::placeholder { color: rgba(26, 26, 46, 0.38) !important; }

            body.light-mode .table td input:disabled {
                background-color: rgba(220, 228, 240, 0.60) !important;
                color: rgba(26, 26, 46, 0.55) !important;
            }

            /* ===== TEXTAREA COMMENT - DARK ===== */
            textarea#comment {
                background-color: rgba(255, 255, 255, 0.1) !important;
                border: 1px solid rgba(255, 255, 255, 0.3) !important;
                color: #ffffff !important;
            }

            textarea#comment:focus {
                background-color: rgba(255, 255, 255, 0.15) !important;
                border-color: rgba(100, 181, 246, 0.5) !important;
                color: #ffffff !important;
            }

            textarea#comment::placeholder { color: rgba(255, 255, 255, 0.5) !important; }

            /* ===== LIGHT MODE - TEXTAREA COMMENT ===== */
            body.light-mode textarea#comment {
                background-color: rgba(255, 255, 255, 0.85) !important;
                border: 1px solid rgba(0, 0, 0, 0.18) !important;
                color: #1a1a2e !important;
            }

            body.light-mode textarea#comment::placeholder { color: rgba(26, 26, 46, 0.38) !important; }

            /* ===== SUBMIT COUNTER ===== */
            #submitCounter, #submitCounter span { color: #ffffff !important; }
            body.light-mode #submitCounter, body.light-mode #submitCounter span { color: #1a1a2e !important; }

            /* ===== BUTTON OPSI DI TABEL - DARK ===== */
            .table .input-group .btn-primary {
                background-color: rgba(8, 65, 150, 0.95) !important;
                border: 2px solid rgba(100, 181, 246, 1) !important;
                color: rgba(100, 181, 246, 1) !important;
            }

            .table .input-group .btn-primary:hover {
                background-color: rgba(5, 45, 110, 1) !important;
                border-color: rgba(144, 202, 249, 1) !important;
                color: rgba(144, 202, 249, 1) !important;
            }

            /* ===== LIGHT MODE - BUTTON OPSI ===== */
            body.light-mode .table .input-group .btn-primary {
                background-color: rgba(61, 121, 176, 0.90) !important;
                border: 2px solid rgba(61, 121, 176, 0.75) !important;
                color: #ffffff !important;
            }

            body.light-mode .table .input-group .btn-primary:hover {
                background-color: rgba(35, 90, 150, 1) !important;
                color: #ffffff !important;
            }

            /* ===== ADD ROW BUTTON ===== */
            body.light-mode .btn-success.btn-sm {
                background-color: rgba(25, 135, 84, 0.90) !important;
                border: 1.5px solid rgba(25, 135, 84, 0.75) !important;
                color: #ffffff !important;
            }

            /* ===== SUBMIT & RESET BAWAH FORM - LIGHT ===== */
            body.light-mode #btn-validate-submit {
                background-color: rgba(61, 121, 176, 0.90) !important;
                border: 1.5px solid rgba(61, 121, 176, 0.75) !important;
                color: #ffffff !important;
                border-radius: 999px !important;
            }

            body.light-mode .d-flex.align-middle.justify-content-center .btn-danger {
                background-color: rgba(180, 40, 50, 0.88) !important;
                border-color: rgba(180, 40, 50, 0.75) !important;
                color: #ffffff !important;
                border-radius: 999px !important;
            }

            /* ===== EDIT & DEL BUTTONS DI TABEL - LIGHT ===== */
            body.light-mode .table .btn-warning {
                background-color: rgba(255, 193, 7, 0.90) !important;
                border-color: rgba(200, 150, 0, 0.7) !important;
                color: #1a1a2e !important;
            }

            body.light-mode .table .btn-danger {
                background-color: rgba(180, 40, 50, 0.88) !important;
                border-color: rgba(180, 40, 50, 0.75) !important;
                color: #ffffff !important;
            }

            /* ===== UPLOAD MONTHLY PLAN BUTTON - LIGHT ===== */
            body.light-mode .col-auto.ms-auto .btn-primary {
                background-color: rgba(61, 121, 176, 0.85) !important;
                border-color: rgba(61, 121, 176, 0.9) !important;
                color: #ffffff !important;
            }
        </style>
    </head>
    <body>
    <div class="filter-area-with-lines">    
        <div class="panamon-bottom-line"></div>
        <div class="panamon-bottomm-line"></div>

        <div class="filter-content">
            <div class="row g-3 align-items-center justify-content-between flex-wrap">
                <div class="col-auto">
                    <form method="get" class="d-flex flex-wrap align-items-center gap-3">
                        <div class="d-flex align-items-center gap-2">
                            <label class="mb-0">Date</label>
                            <input type="date" class="form-control" style="width: 140px;"
                                   name="FilterDate"
                                   value="@Model.CurrentDate.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <label class="mb-0">Machine</label>
                           <select class="form-select-sm" style="width: 70px;" name="FilterMachineCode" asp-for="FilterMachineCode">
                                <option value="MCH1-01">CU</option>
                                <option value="MCH1-02">CS</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary">Search</button>
                        <a href="/Summary/ProductionPlan" class="btn btn-danger">Reset</a>
                    </form>
                </div>

                <div class="col-auto ms-auto">
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                        Upload Monthly Plan
                    </button>
                </div>
            </div>
        </div>
    </div>
            <div class="modal fade" id="uploadModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header d-flex justify-content-between align-items-center">
                            <h5 class="modal-title" id="uploadModalLabel">Upload Monthly Plan</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3 text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-page-handler="DownloadTemplate" asp-route-type="cu" class="btn btn-sm btn-outline-success d-flex align-items-center gap-1">
                                        <i class="bi bi-file-earmark-excel-fill"></i>
                                        Template
                                    </a>
                                </div>
                            </div>
                            <hr />

                            <form method="post" enctype="multipart/form-data" asp-page-handler="Upload">
                                <div class="form-group mb-3">
                                    <label for="UploadedFile" class="form-label fw-bold">Pilih File Excel:</label>
                                    <input type="file" id="UploadedFile" name="UploadedFile" class="form-control" accept=".xlsx, .xls" required>
                                </div>
                                <div class="form-group mb-3">
                                    <label for="TargetMachine" class="form-label fw-bold">Untuk Mesin:</label>
