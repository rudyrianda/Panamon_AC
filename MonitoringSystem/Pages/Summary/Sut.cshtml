    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/sweetalert2.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var statusMessage = '@TempData["StatusMessage"]';
            var message = '@TempData["Message"]';
            if (statusMessage === 'success') {
                Swal.fire({ icon: 'success', title: 'Success', text: message, confirmButtonText: 'OK' });
            } else if (statusMessage === 'error') {
                Swal.fire({ icon: 'error', title: 'Error', text: message, confirmButtonText: 'OK' });
            }
        });

        let submitCount = 0;

        function validateAndSubmit() {
            const rows = document.querySelectorAll('#sut-table-body tr');
            let hasData = false;
            rows.forEach(row => {
                const productName = row.querySelector('input[name^="ProductName"]')?.value.trim();
                if (productName && productName !== '') hasData = true;
            });
            if (!hasData) {
                Swal.fire({ icon: 'warning', title: 'Data Kosong', text: 'Silakan isi minimal satu baris Product Name sebelum submit.', confirmButtonText: 'OK' });
                return;
            }
            Swal.fire({ title: 'Menyimpan Data...', text: 'Mohon tunggu sebentar', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });
            submitCount++;
            document.getElementById('counter').textContent = submitCount;
            document.getElementById('form-sut').submit();
        }

              function openEditModal(i, btn) {
            const row = btn.closest('tr');
            const get = name => row.querySelector(`input[name="${name}[${i}]"]`)?.value ?? '';

            const productId = row.querySelector(`input[name="ProductId[${i}]"]`)?.value ?? '';
            console.log('=== OPEN EDIT MODAL ===');
            console.log('index i:', i);
            console.log('ProductId:', productId);
            console.log('ProductName:', get('ProductName'));
            console.log('MachineCode:', get('MachineCode'));
            console.log('ProdPlan:', get('ProdPlan'));
            console.log('SUT:', get('SUT'));

            document.getElementById('edit-product-id').value     = productId;
            document.getElementById('edit-product-name').value   = get('ProductName');
            document.getElementById('edit-machine-code').value   = get('MachineCode');
            document.getElementById('edit-description').value    = get('Description');
            document.getElementById('edit-prod-plan').value      = get('ProdPlan');
            document.getElementById('edit-sut-val').value        = get('SUT');
            document.getElementById('edit-no-of-operator').value = get('NoOfOperator');
            document.getElementById('edit-qty-hour').value       = get('QtyHour');
            document.getElementById('edit-prod-head-hour').value = get('ProdHeadHour');
            document.getElementById('edit-cycle-time').value     = get('CycleTimeVacum');
            document.getElementById('edit-work-hour').value      = get('WorkHour');

            console.log('=== AFTER SET ===');
            console.log('edit-product-id value:', document.getElementById('edit-product-id').value);

            new bootstrap.Modal(document.getElementById('edit-sut-modal')).show();
        }
        function openDeleteModal(productId) {
            document.getElementById('delete-product-id').value = productId;
            new bootstrap.Modal(document.getElementById('delete-sut-modal')).show();
        }

        document.addEventListener('DOMContentLoaded', function () {
            const sel = document.querySelector('.filter-content select[name="FilterMachineCode"]');
            if (sel && sel.value) sel.classList.add('selected');
            if (sel) sel.addEventListener('change', function () {
                this.value ? this.classList.add('selected') : this.classList.remove('selected');
            });
        });
                document.querySelector('#edit-sut-modal form').addEventListener('submit', function(e) {
            console.log('=== SUBMIT EDIT FORM ===');
            const fd = new FormData(this);
            for (let [k, v] of fd.entries()) {
                console.log(k, ':', v);
            }
        });
    </script>
