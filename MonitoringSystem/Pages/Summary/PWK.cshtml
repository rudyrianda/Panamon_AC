@page
@model MonitoringSystem.Pages.Summary.PWKModel
@{
    ViewData["Title"] = "PWK";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="~/css/Sidebar.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sweetalert2.css" />

    <style>
        /* ============================================================
                           FILTER AREA
                        ============================================================ */
        .filter-area-with-lines {
            position: relative;
            padding: 1px 0;
            margin-bottom: -63px !important;
            margin-top: -20px;
            min-height: 10px;
            width: calc(100% - 14px);
            margin-left: 7px;
            margin-right: 7px;
        }

        .panamon-bottom-line,
        .panamon-bottomm-line {
            position: absolute !important;
            left: -13px !important;
            right: -13px !important;
            height: 2px !important;
            background: rgba(255,255,255,0.04) !important;
            z-index: 999 !important;
            pointer-events: none !important;
            display: block !important;
        }

        .panamon-bottom-line {
            top: 0 !important;
            border-top: 2px solid rgba(255,255,255,0.08) !important;
        }

        .panamon-bottomm-line {
            bottom: 0 !important;
            border-bottom: 2px solid rgba(255,255,255,0.08) !important;
        }

        body.light-mode .panamon-bottom-line {
            border-top-color: rgba(0,0,0,0.10) !important;
            background: rgba(0,0,0,0.03) !important;
        }

        body.light-mode .panamon-bottomm-line {
            border-bottom-color: rgba(0,0,0,0.10) !important;
            background: rgba(0,0,0,0.03) !important;
        }

        .filter-content {
            position: relative;
            z-index: 2;
            padding: 6px 0;
            border-radius: 15px;
            margin-left: -8px;
            margin-right: 7px;
        }

            .filter-content .form-select,
            .filter-content .form-control {
                height: 28px;
                padding: 0 22px 0 8px;
                font-size: 12px;
                line-height: 20px;
                border-radius: 999px;
                background-color: rgba(255,255,255,0.05);
                border: 2px solid rgba(255,255,255,0.5);
                color: #ffffff;
                text-align: center;
                appearance: none;
                -webkit-appearance: none;
                -moz-appearance: none;
            }

            .filter-content .form-select {
                padding: 0 !important;
                padding-left: 12px !important;
                padding-right: 28px !important;
                line-height: 16px;
                background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23ffffff' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
                background-repeat: no-repeat;
                background-position: right 8px center;
                background-size: 10px 10px;
            }

                .filter-content .form-select option {
                    background-color: rgb(30,40,60);
                    color: #ffffff;
                    font-size: 12px;
                }

                .filter-content .form-select.selected {
                    font-weight: 700 !important;
                }

            .filter-content .form-control[type="date"] {
                height: 28px;
                padding: 0 22px 0 8px;
                font-size: 12px;
                line-height: 20px;
                border-radius: 999px;
                background-color: rgba(255,255,255,0.05);
                border: 2px solid rgba(255,255,255,0.5);
                color: #ffffff;
                text-align: center;
                appearance: none;
                -webkit-appearance: none;
                -moz-appearance: none;
            }

                .filter-content .form-control[type="date"]::-webkit-calendar-picker-indicator {
                    filter: invert(1);
                    cursor: pointer;
                    margin-right: 4px;
                }

                .filter-content .form-control[type="date"]:focus {
                    border-color: rgba(100,181,246,1);
                    box-shadow: 0 0 0 0.2rem rgba(100,181,246,0.25);
                }

            .filter-content label {
                color: rgba(255,255,255,0.85);
                font-size: 12px;
                line-height: 20px;
            }

            .filter-content .btn {
                height: 28px;
                min-height: 20px;
                padding: 0 12px;
                font-size: 12px;
                line-height: 20px;
                border-radius: 999px !important;
                font-weight: 600;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .filter-content .btn-primary {
                background-color: rgba(8,65,150,0.95);
                border: 2px solid rgba(100,181,246,1);
                color: rgba(100,181,246,1);
            }

                .filter-content .btn-primary:hover {
                    background-color: rgba(5,45,110,1);
                    border-color: rgba(144,202,249,1);
                    color: rgba(144,202,249,1);
                }

            .filter-content .btn-danger {
                background-color: rgba(140,30,40,0.95);
                border: 2px solid rgba(239,154,154,1);
                color: rgba(239,154,154,1);
            }

                .filter-content .btn-danger:hover {
                    background-color: rgba(110,20,30,1);
                    border-color: rgba(244,143,177,1);
                    color: rgba(244,143,177,1);
                }

        body.light-mode .filter-content label {
            color: #1a1a2e !important;
        }

        body.light-mode .filter-content .form-select {
            background-color: rgba(255,255,255,0.5) !important;
            border-color: rgba(0,0,0,0.2) !important;
            color: #1a1a2e !important;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%231a1a2e' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e") !important;
        }

            body.light-mode .filter-content .form-select option {
                background-color: #ffffff !important;
                color: #1a1a2e !important;
            }

        body.light-mode .filter-content .btn-primary {
            background-color: rgba(61,121,176,0.85) !important;
            border-color: rgba(61,121,176,0.9) !important;
            color: #ffffff !important;
        }

        body.light-mode .filter-content .btn-danger {
            background-color: rgba(180,40,50,0.85) !important;
            border-color: rgba(200,60,70,0.9) !important;
            color: #ffffff !important;
        }

        body.light-mode .filter-content .form-control[type="date"] {
            background-color: rgba(255,255,255,0.5) !important;
            border-color: rgba(0,0,0,0.2) !important;
            color: #1a1a2e !important;
        }

            body.light-mode .filter-content .form-control[type="date"]::-webkit-calendar-picker-indicator {
                filter: none;
            }

            body.light-mode .filter-content .form-control[type="date"]:focus {
                border-color: rgba(61,121,176,1);
                box-shadow: 0 0 0 0.2rem rgba(61,121,246,0.25);
            }

        /* ============================================================
                           CARD WRAPPER
                        ============================================================ */
        .pwk-card {
            margin: 75px 12px 8px;
            background: rgba(255,255,255,0.20) !important;
            border-radius: 12px;
            border: 2px solid rgba(255,255,255,0.3) !important;
            box-shadow: 0 4px 16px rgba(0,0,0,0.2);
        }

        body.light-mode .pwk-card {
            background: rgba(255,255,255,0.55) !important;
            border: 2px solid rgba(200,215,235,0.80) !important;
            box-shadow: 0 4px 20px rgba(0,0,0,0.10) !important;
        }

        .pwk-table-container {
            overflow: hidden;
        }

        :root {
            --sb-w: 8px;
        }

        .pwk-header-wrap {
            overflow: hidden;
            background: rgba(30,40,60,1) !important;
        }

            .pwk-header-wrap table {
                width: calc(100% - var(--sb-w));
                table-layout: fixed;
            }

        .pwk-body-wrap {
            overflow: auto;
            overflow-x: auto;
            max-height: calc(100vh - 280px);
            padding: 8px;
            padding-right: 0;
            overflow-y: scroll;
        }

            .pwk-body-wrap table {
                width: 100%;
                table-layout: fixed;
            }

            .pwk-body-wrap td, .pwk-body-wrap th {
                overflow: hidden;
            }

            .pwk-body-wrap input.form-control {
                width: 100% !important;
                min-width: 0 !important;
                box-sizing: border-box;
            }

            .pwk-body-wrap::-webkit-scrollbar {
                width: var(--sb-w);
                background: rgba(255,255,255,0.05);
            }

            .pwk-body-wrap::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,0.18);
                border-radius: 4px;
            }

        .pwk-header-wrap th {
            background: rgba(30,40,60,1) !important;
            color: #fff !important;
        }

        /* ============================================================
                           PWK TABLE
                        ============================================================ */
        .pwk-tbl {
            --bs-table-bg: transparent;
            --bs-table-color: #ffffff;
            border-collapse: separate !important;
            border-spacing: 0 !important;
            width: 100%;
            margin: 0;
        }

            .pwk-tbl tbody td,
            .pwk-tbl tbody th {
                background-color: rgba(255,255,255,0.08) !important;
                color: #ffffff !important;
                border-color: rgba(255,255,255,0.3) !important;
                padding: 3px 5px;
                vertical-align: middle;
            }

            .pwk-tbl td input.form-control {
                background-color: rgba(255,255,255,0.1) !important;
                border: 1px solid rgba(255,255,255,0.3) !important;
                color: #ffffff !important;
                padding: 4px 8px;
                font-size: 13px;
            }

                .pwk-tbl td input.form-control:focus {
                    background-color: rgba(255,255,255,0.15) !important;
                    border-color: rgba(100,181,246,0.5) !important;
                    color: #ffffff !important;
                    box-shadow: none !important;
                }

                .pwk-tbl td input.form-control::placeholder {
                    color: rgba(255,255,255,0.4) !important;
                }

            .pwk-tbl .btn-warning,
            .pwk-tbl .btn-warning * {
                color: #000000 !important;
            }

        body.light-mode .pwk-tbl thead th {
            background: rgba(25,35,58,0.92) !important;
            color: #ffffff !important;
            border-color: rgba(255,255,255,0.25) !important;
        }

        body.light-mode .pwk-tbl tbody td,
        body.light-mode .pwk-tbl tbody th {
            background-color: rgba(255,255,255,0.50) !important;
            color: #1a1a2e !important;
            border-color: rgba(0,0,0,0.07) !important;
        }

        body.light-mode .pwk-tbl td input.form-control {
            background-color: rgba(255,255,255,0.85) !important;
            border: 1px solid rgba(0,0,0,0.18) !important;
            color: #1a1a2e !important;
        }

            body.light-mode .pwk-tbl td input.form-control::placeholder {
                color: rgba(26,26,46,0.38) !important;
            }

        body.light-mode .pwk-body-wrap::-webkit-scrollbar {
            background: rgba(0,0,0,0.05);
        }

        body.light-mode .pwk-body-wrap::-webkit-scrollbar-thumb {
            background: rgba(0,0,0,0.15);
        }

        /* ============================================================
                           COLUMN WIDTHS
                        ============================================================ */
        .pwk-tbl .col-no {
            width: 50px !important;
            min-width: 50px !important;
            max-width: 50px !important;
        }

        .pwk-tbl .col-model {
            width: 260px !important;
            min-width: 260px !important;
        }

        .pwk-tbl .col-actual {
            width: 140px !important;
            min-width: 140px !important;
        }

        .pwk-tbl .col-action {
            width: 100px !important;
            min-width: 100px !important;
            max-width: 100px !important;
            white-space: nowrap;
            padding-left: 8px !important;
            padding-right: 8px !important;
        }

        /* ============================================================
                           MODAL EDIT PWK (existing)
                        ============================================================ */
        #edit-pwk-modal .modal-content {
            background-color: rgba(20,30,50,0.98) !important;
            border: 1px solid rgba(255,255,255,0.2) !important;
        }

        #edit-pwk-modal .modal-header {
            border-bottom: 1px solid rgba(255,255,255,0.15) !important;
            background-color: transparent !important;
        }

        #edit-pwk-modal .modal-footer {
            border-top: 1px solid rgba(255,255,255,0.15) !important;
            background-color: transparent !important;
        }

        #edit-pwk-modal .modal-title,
        #edit-pwk-modal .modal-body label {
            color: #ffffff !important;
        }

        #edit-pwk-modal .modal-body .form-control {
            background-color: rgba(255,255,255,0.1) !important;
            border: 1px solid rgba(255,255,255,0.3) !important;
            color: #ffffff !important;
        }

            #edit-pwk-modal .modal-body .form-control::placeholder {
                color: rgba(255,255,255,0.4) !important;
            }

        #edit-pwk-modal .btn-close {
            filter: invert(1);
        }

        body.light-mode #edit-pwk-modal .modal-content {
            background-color: #ffffff !important;
        }

        body.light-mode #edit-pwk-modal .modal-title,
        body.light-mode #edit-pwk-modal .modal-body label {
            color: #1a1a2e !important;
        }

        body.light-mode #edit-pwk-modal .modal-body .form-control {
            background-color: #ffffff !important;
            border: 1px solid rgba(0,0,0,0.2) !important;
            color: #1a1a2e !important;
        }

        body.light-mode #edit-pwk-modal .btn-close {
            filter: none;
        }

        /* ============================================================
                           MODAL MISSING SERIAL
                        ============================================================ */
        #missing-serial-modal .modal-dialog {
            max-width: 560px;
        }

        #missing-serial-modal .modal-content {
            background-color: rgba(15, 25, 45, 0.98) !important;
            border: 1px solid rgba(100, 181, 246, 0.25) !important;
            border-radius: 12px;
            overflow: hidden;
        }

        #missing-serial-modal .modal-header {
            background: rgba(30, 40, 65, 1) !important;
            border-bottom: 1px solid rgba(100, 181, 246, 0.2) !important;
            padding: 12px 16px;
        }

        #missing-serial-modal .modal-title {
            color: #ffffff !important;
            font-size: 14px;
            font-weight: 600;
        }

        #missing-serial-modal .btn-close {
            filter: invert(1);
        }

        /* Info bar: model, serial first, serial last */
        .ms-info-bar {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            padding: 10px 16px;
            background: rgba(100, 181, 246, 0.07);
            border-bottom: 1px solid rgba(100, 181, 246, 0.15);
        }

        .ms-info-chip {
            display: flex;
            flex-direction: column;
            gap: 1px;
        }

            .ms-info-chip .chip-label {
                font-size: 10px;
                color: rgba(100, 181, 246, 0.7);
                text-transform: uppercase;
                letter-spacing: 0.5px;
                font-weight: 600;
            }

            .ms-info-chip .chip-value {
                font-size: 13px;
                color: #ffffff;
                font-weight: 600;
            }

            .ms-info-chip.chip-serial .chip-value {
                font-family: 'Courier New', monospace;
                color: rgba(144, 202, 249, 1);
            }

        /* Missing serial table */
        .ms-table-wrap {
            max-height: 380px;
            overflow-y: auto;
            padding: 0;
        }

            .ms-table-wrap::-webkit-scrollbar {
                width: 6px;
                background: rgba(255,255,255,0.03);
            }

            .ms-table-wrap::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,0.15);
                border-radius: 3px;
            }

        .ms-tbl {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin: 0;
            font-size: 13px;
        }

            .ms-tbl thead th {
                position: sticky;
                top: 0;
                z-index: 2;
                background: rgba(30, 40, 65, 1) !important;
                color: rgba(100, 181, 246, 0.9) !important;
                font-size: 11px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                padding: 8px 14px;
                border-bottom: 1px solid rgba(100, 181, 246, 0.2) !important;
            }

            .ms-tbl tbody tr {
                transition: background 0.15s;
            }

                .ms-tbl tbody tr:hover td {
                    background-color: rgba(100, 181, 246, 0.08) !important;
                }

            .ms-tbl tbody td {
                background-color: rgba(255,255,255,0.04) !important;
                color: #ffffff !important;
                border-color: rgba(255,255,255,0.08) !important;
                padding: 7px 14px;
                border-bottom: 1px solid rgba(255,255,255,0.06) !important;
                vertical-align: middle;
            }

                .ms-tbl tbody td.td-serial {
                    font-family: 'Courier New', monospace;
                    font-size: 13px;
                    color: rgba(200, 230, 255, 1) !important;
                    letter-spacing: 0.5px;
                }

                .ms-tbl tbody td.td-action {
                    text-align: center;
                    width: 90px;
                }

        /* Add button per row */
        .btn-add-serial {
            font-size: 11px;
            font-weight: 600;
            padding: 3px 12px;
            border-radius: 999px;
            background: rgba(46, 125, 50, 0.8);
            border: 1px solid rgba(102, 187, 106, 0.7);
            color: rgba(165, 214, 167, 1) !important;
            transition: all 0.15s;
            white-space: nowrap;
        }

            .btn-add-serial:hover {
                background: rgba(56, 142, 60, 1);
                border-color: rgba(129, 199, 132, 1);
                color: #ffffff !important;
            }

            .btn-add-serial:disabled {
                background: rgba(40,40,40,0.5);
                border-color: rgba(255,255,255,0.1);
                color: rgba(255,255,255,0.3) !important;
                cursor: not-allowed;
            }

        /* Added badge */
        .badge-added {
            font-size: 10px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 999px;
            background: rgba(27, 94, 32, 0.7);
            border: 1px solid rgba(102, 187, 106, 0.5);
            color: rgba(165, 214, 167, 1);
            letter-spacing: 0.3px;
        }

        /* Empty state */
        .ms-empty {
            text-align: center;
            padding: 32px 16px;
            color: rgba(255,255,255,0.35);
            font-size: 13px;
        }

            .ms-empty .ms-empty-icon {
                font-size: 32px;
                margin-bottom: 8px;
                opacity: 0.4;
            }

        /* Loading spinner */
        .ms-loading {
            text-align: center;
            padding: 32px 16px;
            color: rgba(100, 181, 246, 0.6);
            font-size: 13px;
        }

        /* Modal footer */
        #missing-serial-modal .modal-footer {
            border-top: 1px solid rgba(255,255,255,0.08) !important;
            background: rgba(30, 40, 65, 0.6) !important;
            padding: 10px 16px;
        }

        /* Summary count */
        .ms-count-badge {
            font-size: 11px;
            background: rgba(100, 181, 246, 0.15);
            border: 1px solid rgba(100, 181, 246, 0.3);
            color: rgba(100, 181, 246, 0.9);
            border-radius: 999px;
            padding: 2px 10px;
            font-weight: 600;
        }

        /* ── LIGHT MODE overrides ── */
        body.light-mode #missing-serial-modal .modal-content {
            background-color: #f4f7fb !important;
            border: 1px solid rgba(61, 121, 176, 0.3) !important;
        }

        body.light-mode #missing-serial-modal .modal-header {
            background: rgba(25, 45, 80, 0.92) !important;
        }

        body.light-mode #missing-serial-modal .btn-close {
            filter: invert(1);
        }

        body.light-mode .ms-info-bar {
            background: rgba(61, 121, 176, 0.08);
            border-bottom-color: rgba(61, 121, 176, 0.2);
        }

        body.light-mode .ms-info-chip .chip-label {
            color: rgba(61, 121, 176, 0.8);
        }

        body.light-mode .ms-info-chip .chip-value {
            color: #1a1a2e;
        }

        body.light-mode .ms-info-chip.chip-serial .chip-value {
            color: rgba(30, 80, 160, 1);
        }

        body.light-mode .ms-tbl thead th {
            background: rgba(30, 50, 90, 0.9) !important;
            color: rgba(144, 202, 249, 1) !important;
        }

        body.light-mode .ms-tbl tbody td {
            background-color: rgba(255,255,255,0.75) !important;
            color: #1a1a2e !important;
            border-color: rgba(0,0,0,0.06) !important;
        }

            body.light-mode .ms-tbl tbody td.td-serial {
                color: rgba(20, 60, 140, 1) !important;
            }

        body.light-mode .ms-tbl tbody tr:hover td {
            background-color: rgba(61, 121, 176, 0.08) !important;
        }

        body.light-mode .ms-loading {
            color: rgba(61, 121, 176, 0.8);
        }

        body.light-mode .ms-empty {
            color: rgba(0,0,0,0.35);
        }

        body.light-mode .ms-count-badge {
            background: rgba(61, 121, 176, 0.1);
            border-color: rgba(61, 121, 176, 0.3);
            color: rgba(30, 80, 160, 1);
        }

        body.light-mode #missing-serial-modal .modal-footer {
            background: rgba(240, 245, 255, 0.9) !important;
            border-top-color: rgba(0,0,0,0.08) !important;
        }

        body.light-mode .ms-table-wrap::-webkit-scrollbar {
            background: rgba(0,0,0,0.04);
        }

        body.light-mode .ms-table-wrap::-webkit-scrollbar-thumb {
            background: rgba(0,0,0,0.12);
        }
    </style>
</head>
<body>

    <div class="filter-area-with-lines">
        <div class="panamon-bottom-line"></div>
        <div class="panamon-bottomm-line"></div>
        <div class="filter-content">
            <div class="row g-3 align-items-center justify-content-between flex-wrap">
                <div class="col-auto">
                    <form method="get" class="d-flex flex-wrap align-items-center gap-3">
                        <div class="d-flex align-items-center gap-2">
                            <label class="mb-0">Tanggal</label>
                            <input type="date" class="form-control" style="width: 140px;"
                                   name="FilterDate"
                                   value="@(string.IsNullOrEmpty(Model.FilterDate) ? DateTime.Now.ToString("yyyy-MM-dd") : Model.FilterDate)" />
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <label class="mb-0">Machine Line</label>
                            <select class="form-select" style="width: 120px;" name="FilterMachineLine" asp-for="FilterMachineLine">
                                <option value="">All</option>
                                <option value="MCH1-01">CU</option>
                                <option value="MCH1-02">CS</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">Search</button>
                        <a href="/Summary/Pwk" class="btn btn-danger">Reset</a>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="pwk-card">
        <form id="form-pwk" method="post" asp-page-handler="SavePwk">
            <input type="hidden" name="FilterDate" value="@Model.FilterDate" />
            <input type="hidden" name="FilterMachineLine" value="@Model.FilterMachineLine" />

            <div class="pwk-table-container">

                <!-- HEADER -->
                <div class="pwk-header-wrap">
                    <table class="table table-bordered mb-0 pwk-tbl">
                        <thead>
                            <tr>
                                <th class="col-no">No</th>
                                <th class="col-model">Model</th>
                                <th class="col-actual">Actual</th>
                                <th class="col-action">Action</th>
                            </tr>
                        </thead>
                    </table>
                </div>

                <!-- BODY -->
                <div class="pwk-body-wrap">
                    <table class="table table-bordered mb-0 pwk-tbl">
                        <tbody id="pwk-table-body">
                            @{
                                int minRows = 15;
                                int dataCount = Model.listData?.Count ?? 0;
                                int totalRows = Math.Max(dataCount, minRows);
                            }

                            @for (int i = 0; i < totalRows; i++)
                            {
                                var item = dataCount > i ? Model.listData[i] : null;

                                <tr>
                                    <th scope="row" class="text-center align-middle row-number col-no">@(i + 1)</th>

                                    <td class="col-model">
                                        <input type="hidden" name="DataId[@i]" value="@(item?.Data_Id ?? "")" />
                                        <input type="hidden" class="row-machine" value="@(item?.MachineLine ?? "")" />
                                        <input type="hidden" class="row-serial-first" value="@(item?.SerialFirst ?? "")" />
                                        <input type="hidden" class="row-serial-last" value="@(item?.SerialLast ?? "")" />
                                        <input type="text" class="form-control" name="Model[@i]"
                                               value="@(item?.Model ?? "")" placeholder="Model" />
                                    </td>

                                    <td class="col-actual">
                                        <input type="text" class="form-control" name="Actual[@i]"
                                               value="@(item?.Actual?.ToString() ?? "")" placeholder="Actual" />
                                    </td>

                                    <td class="col-action text-center">
                                        @if (item != null)
                                        {
                                            <button type="button" class="btn btn-warning btn-sm"
                                                    onclick="openMissingSerialModal(this)"
                                                    data-product-id="@item.Data_Id"
                                                    data-machine-code="@item.MachineLine"
                                                    data-model="@item.Model"
                                                    data-filter-date="@Model.FilterDate"
                                                    data-serial-first="@(item.SerialFirst ?? "")"
                                                    data-serial-last="@(item.SerialLast ?? "")">
                                                Edit
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </form>
    </div>

    <!-- ══════════════════════════════════════════════════════════
         MODAL MISSING SERIAL
    ══════════════════════════════════════════════════════════ -->
    <div class="modal fade" id="missing-serial-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">
                        <span style="opacity:0.6;font-weight:400;font-size:12px;">Missing Serial</span>
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <!-- Info bar -->
                <div class="ms-info-bar" id="ms-info-bar">
                    <div class="ms-info-chip">
                        <span class="chip-label">Model</span>
                        <span class="chip-value" id="ms-model-name">—</span>
                    </div>
                    <div class="ms-info-chip chip-serial" style="margin-left:auto;">
                        <span class="chip-label">Serial Pertama</span>
                        <span class="chip-value" id="ms-serial-first">—</span>
                    </div>
                    <div class="ms-info-chip chip-serial">
                        <span class="chip-label">Serial Terakhir</span>
                        <span class="chip-value" id="ms-serial-last">—</span>
                    </div>
                </div>

                <!-- Table -->
                <div class="ms-table-wrap">
                    <div id="ms-loading" class="ms-loading" style="display:none;">
                        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                        Memuat missing serial...
                    </div>
                    <div id="ms-empty" class="ms-empty" style="display:none;">
                        <div class="ms-empty-icon">✓</div>
                        Tidak ada serial yang hilang
                    </div>
                    <table class="ms-tbl" id="ms-table" style="display:none;">
                        <thead>
                            <tr>
                                <th>Missing Serial</th>
                                <th style="text-align:center;width:90px;">Action</th>
                            </tr>
                        </thead>
                        <tbody id="ms-tbody"></tbody>
                    </table>
                </div>

                <div class="modal-footer justify-content-between">
                    <span class="ms-count-badge" id="ms-count-badge">0 serial hilang</span>
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Tutup</button>
                </div>

            </div>
        </div>
    </div>

    <!-- MODAL EDIT (existing) -->
    <div class="modal fade" id="edit-pwk-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Data</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="Update">
                    <input type="hidden" id="edit-data-id" name="DataId" />
                    <div class="modal-body">
                        <div class="mb-2">
                            <label class="form-label">Model</label>
                            <input type="text" class="form-control" id="edit-model" name="Model" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Actual</label>
                            <input type="number" step="0.01" class="form-control" id="edit-actual" name="Actual" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/sweetalert2.min.js"></script>

    <script>
        // ── State aktif modal ───────────────────────────────────
        let _msProductId   = '';
        let _msMachineCode = '';
        let _msFilterDate  = '';
        let _msMissingList = [];

        document.addEventListener("DOMContentLoaded", function () {
            var statusMessage = '@TempData["StatusMessage"]';
            var message = '@TempData["Message"]';
            if (statusMessage === 'success') {
                Swal.fire({ icon: 'success', title: 'Success', text: message, confirmButtonText: 'OK' });
            } else if (statusMessage === 'error') {
                Swal.fire({ icon: 'error', title: 'Error', text: message, confirmButtonText: 'OK' });
            }

            const body   = document.querySelector('.pwk-body-wrap');
            const header = document.querySelector('.pwk-header-wrap');
            if (body && header) {
                body.addEventListener('scroll', () => { header.scrollLeft = body.scrollLeft; });
            }

            const sel = document.querySelector('.filter-content select[name="FilterMachineLine"]');
            if (sel && sel.value) sel.classList.add('selected');
            if (sel) sel.addEventListener('change', function () {
                this.value ? this.classList.add('selected') : this.classList.remove('selected');
            });

            const sbW = body ? (body.offsetWidth - body.clientWidth) : 8;
            document.documentElement.style.setProperty('--sb-w', sbW + 'px');
        });

        // ── Buka modal missing serial ───────────────────────────
        function openMissingSerialModal(btn) {
            _msProductId   = btn.dataset.productId;
            _msMachineCode = btn.dataset.machineCode;
            _msFilterDate  = btn.dataset.filterDate;
            const modelName = btn.dataset.model;

            // Set info bar langsung dari data attributes — tidak perlu tunggu AJAX
            document.getElementById('ms-model-name').textContent   = modelName || '—';
            document.getElementById('ms-serial-first').textContent = btn.dataset.serialFirst || '—';
            document.getElementById('ms-serial-last').textContent  = btn.dataset.serialLast  || '—';
            document.getElementById('ms-count-badge').textContent  = '—';

            // Show loading, hide others
            setMsState('loading');

            new bootstrap.Modal(document.getElementById('missing-serial-modal')).show();

            fetchMissingSerials();
        }

        function setMsState(state) {
            document.getElementById('ms-loading').style.display = state === 'loading' ? '' : 'none';
            document.getElementById('ms-empty').style.display   = state === 'empty'   ? '' : 'none';
            document.getElementById('ms-table').style.display   = state === 'table'   ? '' : 'none';
        }

        // ── Fetch missing serial via AJAX ───────────────────────
        async function fetchMissingSerials() {
            try {
                const params = new URLSearchParams({
                    productId:   _msProductId,
                    machineCode: _msMachineCode,
                    filterDate:  _msFilterDate || new Date().toISOString().split('T')[0]
                });

                const res  = await fetch(`?handler=MissingSerials&${params}`);
                const data = await res.json();

                if (data.error) {
                    setMsState('empty');
                    document.getElementById('ms-empty').innerHTML =
                        `<div class="ms-empty-icon">⚠</div>Error: ${data.error}`;
                    return;
                }

                // Update info bar serial TIDAK perlu — sudah diisi dari data attributes
                // data.first / data.last tetap dipakai untuk fallback kalau data attribute kosong
                if (!document.getElementById('ms-serial-first').textContent || document.getElementById('ms-serial-first').textContent === '—') {
                    document.getElementById('ms-serial-first').textContent = data.first || '—';
                    document.getElementById('ms-serial-last').textContent  = data.last  || '—';
                }

                _msMissingList = data.serials || [];
                renderMissingTable(_msMissingList);

            } catch (err) {
                setMsState('empty');
                document.getElementById('ms-empty').innerHTML =
                    `<div class="ms-empty-icon">⚠</div>Gagal memuat data`;
            }
        }

        // ── Render tabel missing serial ─────────────────────────
        function renderMissingTable(serials) {
            const tbody = document.getElementById('ms-tbody');
            const badge = document.getElementById('ms-count-badge');

            tbody.innerHTML = '';

            const remaining = serials.filter(s => s !== null);

            if (remaining.length === 0) {
                setMsState('empty');
                badge.textContent = '0 serial hilang';
                return;
            }

            setMsState('table');
            badge.textContent = `${remaining.length} serial hilang`;

            serials.forEach((sn, idx) => {
                if (sn === null) return; // sudah di-add, skip

                const tr = document.createElement('tr');
                tr.dataset.idx = idx;
                tr.innerHTML = `
                    <td class="td-serial">${sn}</td>
                    <td class="td-action">
                        <button type="button" class="btn-add-serial"
                                onclick="addSerial(this, ${idx}, '${sn}')">
                            + Add
                        </button>
                    </td>`;
                tbody.appendChild(tr);
            });
        }

        // ── Add serial ──────────────────────────────────────────
        async function addSerial(btn, idx, serialNumber) {
            btn.disabled = true;
            btn.textContent = '...';

            try {
                const res = await fetch('?handler=AddSerial', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getAntiForgeryToken()
                    },
                    body: JSON.stringify({
                        productId:    _msProductId,
                        machineCode:  _msMachineCode,
                        serialNumber: String(serialNumber),
                        filterDate:   _msFilterDate || new Date().toISOString().split('T')[0]
                    })
                });

                const data = await res.json();

                if (data.success) {
                    // Tandai sebagai added: ganti tombol dengan badge, hapus row dengan animasi
                    const td = btn.closest('td');
                    td.innerHTML = `<span class="badge-added">✓ Added</span>`;

                    // Hapus row setelah sebentar
                    setTimeout(() => {
                        const row = td.closest('tr');
                        row.style.transition = 'opacity 0.3s, transform 0.3s';
                        row.style.opacity = '0';
                        row.style.transform = 'translateX(8px)';
                        setTimeout(() => {
                            // Tandai null di list
                            _msMissingList[idx] = null;
                            row.remove();

                            // Update badge count
                            const remaining = _msMissingList.filter(s => s !== null).length;
                            const badge = document.getElementById('ms-count-badge');
                            badge.textContent = `${remaining} serial hilang`;

                            // Kalau semua sudah di-add, tampilkan empty
                            if (remaining === 0) setMsState('empty');
                        }, 300);
                    }, 600);

                } else {
                    btn.disabled = false;
                    btn.textContent = '+ Add';
                    Swal.fire({ icon: 'error', title: 'Gagal', text: data.error || 'Terjadi kesalahan', confirmButtonText: 'OK' });
                }

            } catch (err) {
                btn.disabled = false;
                btn.textContent = '+ Add';
                Swal.fire({ icon: 'error', title: 'Error', text: 'Gagal menghubungi server', confirmButtonText: 'OK' });
            }
        }

        // ── Anti-forgery token helper ───────────────────────────
        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value
                ?? document.cookie.split(';').find(c => c.trim().startsWith('XSRF-TOKEN='))?.split('=')[1]
                ?? '';
        }

        // ── Existing edit modal (kept for backward compat) ──────
        function openEditModal(i, btn) {
            const row = btn.closest('tr');
            const get = name => row.querySelector(`input[name="${name}[${i}]"]`)?.value ?? '';
            document.getElementById('edit-data-id').value = row.querySelector(`input[name="DataId[${i}]"]`)?.value ?? '';
            document.getElementById('edit-model').value   = get('Model');
            document.getElementById('edit-actual').value  = get('Actual');
            new bootstrap.Modal(document.getElementById('edit-pwk-modal')).show();
        }
    </script>
</body>
</html>